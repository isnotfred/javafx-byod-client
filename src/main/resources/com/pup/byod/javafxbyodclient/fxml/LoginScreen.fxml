<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<VBox stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.LoginScreenController"
      alignment="CENTER" spacing="15.0" styleClass="login-root">
    
    <VBox alignment="CENTER" spacing="5.0">
        <padding>
            <Insets bottom="10.0"/>
        </padding>
        <Label text="BYOD Device Management System" styleClass="login-header"/>
        <Label text="Sign in to your account" styleClass="login-subheader"/>
    </VBox>

    <VBox spacing="25.0" styleClass="login-card" maxWidth="450.0" prefWidth="400.0">
        <padding>
            <Insets top="40.0" right="30.0" bottom="40.0" left="30.0"/>
        </padding>
        
        <!-- Username Field -->
        <VBox spacing="8.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="svg-icon-black"/>
                <Label text="Username/Email" styleClass="login-label"/>
            </HBox>
            <TextField fx:id="usernameField" promptText="Enter email or username" styleClass="login-textfield"/>
        </VBox>
        
        <!-- Password Field -->
        <VBox spacing="8.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z" styleClass="svg-icon-black"/>
                <Label text="Password" styleClass="login-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Hyperlink fx:id="forgotPasswordLink" text="Forgot Password?" onAction="#handleForgotPassword" styleClass="forgot-password-link"/>
            </HBox>
            <StackPane alignment="CENTER_RIGHT">
                <TextField fx:id="passwordVisibleField" promptText="Enter password" styleClass="login-textfield" prefWidth="Infinity" visible="false" managed="false"/>
                <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="login-textfield" prefWidth="Infinity"/>
                
                <Button onAction="#togglePasswordVisibility" style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <SVGPath fx:id="passwordToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" styleClass="svg-icon-black"/>
                    </graphic>
                    <StackPane.margin>
                        <Insets right="5.0"/>
                    </StackPane.margin>
                </Button>
            </StackPane>
        </VBox>
        
        <Region prefHeight="5.0"/>
        
        <!-- Login Button -->
        <Button onAction="#handleLogin" maxWidth="Infinity" styleClass="login-btn" defaultButton="true">
            <graphic>
                <HBox alignment="CENTER" spacing="8.0">
                    <Label text="LOGIN" styleClass="login-label"/>
                    <SVGPath content="M16.01 11H4v2h12.01v3L20 12l-3.99-4v3z" styleClass="svg-icon-black"/>
                </HBox>
            </graphic>
        </Button>
    </VBox>
</VBox>
