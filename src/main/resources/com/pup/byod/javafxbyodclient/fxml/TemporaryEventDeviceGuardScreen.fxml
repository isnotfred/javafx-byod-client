<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.TemporaryEventDeviceGuardScreenController"
      spacing="10.0" VBox.vgrow="ALWAYS">
    
    <Label text="Temporary Event Device Admission Scanner" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="eventRequestIdField" promptText="Enter Event Request ID" prefWidth="200.0"/>
        <Button text="Lookup Event Devices" onAction="#handleSearchEvent"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Verify Selected Device" onAction="#handleVerify" style="-fx-text-fill: green; -fx-font-weight: bold;"/>
    </HBox>
    
    <TableView fx:id="itemsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colItemId" text="Item ID" prefWidth="80.0"/>
            <TableColumn fx:id="colItemName" text="Device Name" prefWidth="250.0"/>
            <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="200.0"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120.0"/>
        </columns>
    </TableView>
</VBox>
