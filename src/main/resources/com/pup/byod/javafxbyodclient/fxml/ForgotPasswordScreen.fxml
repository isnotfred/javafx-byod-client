<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ForgotPasswordScreenController"
      spacing="15.0" alignment="CENTER" prefWidth="400.0" prefHeight="200.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Forgot Password" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="Please enter your email to request a reset token:" wrapText="true"/>

    <HBox spacing="10.0" alignment="CENTER">
        <Label text="Email:"/>
        <TextField fx:id="emailField" promptText="Enter your registered email" prefWidth="250.0"/>
    </HBox>

    <HBox spacing="15.0" alignment="CENTER">
        <Button text="Submit Request" onAction="#handleSubmit" style="-fx-font-weight: bold;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</VBox>
