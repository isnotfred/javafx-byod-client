<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<VBox stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ForgotPasswordScreenController"
      alignment="CENTER" spacing="15.0" style="-fx-background-color: transparent;">

    <VBox spacing="25.0" styleClass="login-card" maxWidth="450.0" prefWidth="400.0">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
        </padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="5.0">
            <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z" style="-fx-fill: #F59E0B; -fx-scale-x: 1.5; -fx-scale-y: 1.5;">
                <VBox.margin>
                    <Insets bottom="10.0"/>
                </VBox.margin>
            </SVGPath>
            <Label text="Reset Password" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <Label text="Enter your email to request a reset token." style="-fx-font-size: 13px; -fx-text-fill: #64748B;" wrapText="true" textAlignment="CENTER"/>
        </VBox>
        
        <!-- Email Field -->
        <VBox spacing="8.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <SVGPath content="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z" styleClass="svg-icon-black"/>
                <Label text="Registered Email" styleClass="login-label"/>
            </HBox>
            <TextField fx:id="emailField" promptText="Enter your email address" styleClass="login-textfield"/>
        </VBox>
        
        <VBox spacing="10.0">
            <Button text="Submit Request" onAction="#handleSubmit" maxWidth="Infinity" styleClass="login-btn"/>
            <Button text="Cancel" onAction="#handleCancel" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </VBox>
    </VBox>
</VBox>
