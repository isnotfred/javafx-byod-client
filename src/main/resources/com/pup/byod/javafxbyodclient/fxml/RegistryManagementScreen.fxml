<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pup.byod.javafxbyodclient.controller.RegistryManagementScreenController"
           HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
           
    <!-- Layer 1 (Bottom): Main View -->
    <VBox spacing="15.0">
        <padding>
            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
        </padding>
        
        <!-- Hero Header Banner -->
        <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="Student Registry Management" styleClass="welcome-title"/>
            <Label text="View and update registered students, verify hardware credentials, and manage campus accessibility records." styleClass="welcome-subtitle"/>
        </VBox>
        
        <!-- Directory Registry Card -->
        <VBox spacing="12.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search student ID or Name..." HBox.hgrow="ALWAYS" styleClass="modern-textfield" prefHeight="38.0" maxWidth="300.0"/>
                <Button text="Search" onAction="#handleSearch" styleClass="action-btn, action-btn-primary" prefHeight="38.0"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Import Students" onAction="#handleImportCsv" styleClass="action-btn, action-btn-success" prefHeight="38.0"/>
                <Button text="Import Devices" onAction="#handleImportDevicesCsv" styleClass="action-btn, action-btn-success" prefHeight="38.0"/>
                <Button text="Export Students" onAction="#handleExportStudents" styleClass="action-btn" prefHeight="38.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569;"/>
                <Button text="Add Student" onAction="#openAddOverlay" styleClass="action-btn, action-btn-warning" prefHeight="38.0"/>
                <Button fx:id="editSelectedBtn" text="Edit Selected" onAction="#openEditOverlay" disable="true" styleClass="action-btn, action-btn-primary" prefHeight="38.0"/>
            </HBox>
            
            <TableView fx:id="studentTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="300.0">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="150.0"/>
                    <TableColumn fx:id="colStudentName" text="Full Name" prefWidth="250.0"/>
                    <TableColumn fx:id="colStudentCourse" text="Course &amp; Section" prefWidth="180.0"/>
                    <TableColumn fx:id="colStudentStatus" text="Status" prefWidth="100.0"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
    
    <!-- Layer 2 (Top): Centered Unified Registry Form Overlay -->
    <StackPane fx:id="formOverlay" visible="false" style="-fx-background-color: rgba(16, 42, 67, 0.45);" alignment="CENTER">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        
        <!-- Unified Registry Form Card -->
        <VBox spacing="0.0" maxHeight="620.0" maxWidth="650.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 15, 0, 0, 8);">
            
            <!-- Sticky Header Section -->
            <VBox spacing="10.0" style="-fx-padding: 20px 20px 10px 20px;">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Registry Profile &amp; Device Entry Form" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#handleCloseOverlay" styleClass="overlay-close-btn"/>
                </HBox>
                <Separator/>
            </VBox>
            
            <!-- Scrollable Content Section -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                
                <VBox spacing="15.0" style="-fx-padding: 0px 20px 20px 20px; -fx-background-color: transparent;">
                    
                    <!-- SECTION I: Student Details -->
                    <Label text="I. Student Registry Details" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                    
                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30.0" halignment="RIGHT"/>
                            <ColumnConstraints percentWidth="70.0"/>
                        </columnConstraints>
                        
                        <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <TextField fx:id="studentIdField" promptText="e.g. 2021-10023" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <TextField fx:id="firstNameField" promptText="e.g. Juan" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Label text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <TextField fx:id="lastNameField" promptText="e.g. Dela Cruz" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        
                        <Label text="Course &amp; Section:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                        <TextField fx:id="courseYearLevelField" promptText="e.g. BSIT 3-1" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        
                        <Label text="Student Status:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                        <ComboBox fx:id="studentStatusBox" promptText="Select Status" styleClass="modern-combo-box" maxWidth="Infinity" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    </GridPane>
                    
                    <Separator/>
                    
                    <!-- SECTION II: Device Details -->
                    <Label text="II. Linked Device Details" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                    
                    <VBox spacing="5.0">
                        <Label text="Student's Registered Devices:" styleClass="form-label"/>
                        <TableView fx:id="deviceTable" prefHeight="120.0" minHeight="90.0" styleClass="modern-table">
                            <columnResizePolicy>
                                <TableView fx:constant="UNCONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colDeviceId" text="ID" prefWidth="50.0" minWidth="50.0"/>
                                <TableColumn fx:id="colDeviceName" text="Device Name" prefWidth="120.0" minWidth="120.0"/>
                                <TableColumn fx:id="colDeviceType" text="Type" prefWidth="120.0" minWidth="120.0"/>
                                <TableColumn fx:id="colDeviceBrand" text="Brand" prefWidth="100.0" minWidth="100.0"/>
                                <TableColumn fx:id="colDeviceSerialNumber" text="Serial Number" prefWidth="140.0" minWidth="140.0"/>
                                <TableColumn fx:id="colDeviceRegStatus" text="Registration" prefWidth="110.0" minWidth="110.0"/>
                                <TableColumn fx:id="colDeviceStatus" text="Status" prefWidth="90.0" minWidth="90.0"/>
                            </columns>
                        </TableView>
                    </VBox>
                    
                    <GridPane hgap="10.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30.0" halignment="RIGHT"/>
                            <ColumnConstraints percentWidth="70.0"/>
                        </columnConstraints>
                        
                        <Label text="Device Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <TextField fx:id="deviceNameField" promptText="e.g. Dell XPS" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        
                        <Label text="Device Brand:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <TextField fx:id="brandField" promptText="e.g. Dell" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        
                        <Label text="Device Model:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <TextField fx:id="modelField" promptText="e.g. XPS 15 9520" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        
                        <Label text="Device Serial Number:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                        <TextField fx:id="serialNumberField" promptText="e.g. SN-DELL-12345" styleClass="modern-textfield" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        
                        <Label text="Device Type:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                        <ComboBox fx:id="deviceTypeBox" promptText="Select Device Type" styleClass="modern-combo-box" maxWidth="Infinity" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        
                        <Label text="Device Purpose:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="form-label"/>
                        <ComboBox fx:id="devicePurposeBox" promptText="Select Device Purpose" styleClass="modern-combo-box" maxWidth="Infinity" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                        
                        <Label text="Device Status:" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="form-label"/>
                        <ComboBox fx:id="deviceStatusBox" promptText="Select Status" styleClass="modern-combo-box" maxWidth="Infinity" prefHeight="38.0" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                    </GridPane>
                    
                    <Separator/>
                    
                    <!-- Unified CRUD Actions inside overlay form -->
                    <HBox spacing="12.0" alignment="CENTER_RIGHT">
                        <Button text="Cancel / Close" onAction="#handleCloseOverlay" styleClass="action-btn, action-btn-secondary" prefHeight="38.0"/>
                        <Button text="Clear Form" onAction="#handleClearForm" styleClass="action-btn" prefHeight="38.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569;"/>
                        <Button text="Deactivate Record" onAction="#handleDeactivateRecord" styleClass="action-btn, action-btn-danger" prefHeight="38.0"/>
                        <Button text="Save Record" onAction="#handleSaveRecord" styleClass="action-btn, action-btn-primary" prefHeight="38.0"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>
    
</StackPane>
