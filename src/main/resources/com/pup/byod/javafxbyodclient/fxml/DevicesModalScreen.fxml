<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" prefWidth="760.0" prefHeight="400.0" 
      style="-fx-background-color: #FFFFFF; -fx-padding: 20px; -fx-border-color: #CBD5E1; -fx-border-width: 2px; -fx-border-radius: 8px; -fx-background-radius: 8px;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.DevicesModalScreenController"
      stylesheets="@../css/admin_dashboard_styles.css">
      
    <!-- Table Title and Tip -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Select Devices to Log" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="* Auto-selected all by default" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-text-fill: #64748B;"/>
    </HBox>
    
    <!-- Devices Checklist Table -->
    <TableView fx:id="devicesTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colSelect" text="Select" prefWidth="95.0" style="-fx-alignment: CENTER;" reorderable="false"/>
            <TableColumn fx:id="colDevName" text="Device Name" prefWidth="180.0" reorderable="false"/>
            <TableColumn fx:id="colDevBrand" text="Brand" prefWidth="110.0" reorderable="false"/>
            <TableColumn fx:id="colDevModel" text="Model" prefWidth="110.0" reorderable="false"/>
            <TableColumn fx:id="colDevSerial" text="Serial Number" prefWidth="180.0" reorderable="false"/>
            <TableColumn fx:id="colDevQuantity" text="Qty" prefWidth="70.0" style="-fx-alignment: CENTER;" reorderable="false"/>
        </columns>
    </TableView>
    
    <!-- Action Buttons Bar -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" prefHeight="38.0" prefWidth="100.0" styleClass="action-btn" style="-fx-background-color: #F1F5F9; -fx-text-fill: #475569; -fx-border-color: #CBD5E1; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-cursor: hand;"/>
        <Button fx:id="btnAction" text="Log Entry" onAction="#handleAction" prefHeight="38.0" prefWidth="180.0" styleClass="action-btn" style="-fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
    
</VBox>
