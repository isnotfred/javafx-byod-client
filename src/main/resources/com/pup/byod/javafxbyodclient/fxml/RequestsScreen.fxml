<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<StackPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pup.byod.javafxbyodclient.controller.RequestsScreenController"
           HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
           
    <!-- Main Content Layer -->
    <VBox spacing="15.0">
        <padding>
            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
        </padding>
        
        <!-- Hero Header -->
        <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="BYOD Access Requests" styleClass="welcome-title"/>
            <Label text="Manage and review student Academic BYOD credentials and temporary Event hardware requests." styleClass="welcome-subtitle"/>
        </VBox>
        
        <!-- Requests List Card -->
        <VBox spacing="12.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <!-- Search Bar -->
                <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="250.0">
                    <TextField fx:id="searchField" promptText="Filter by Student ID..." styleClass="modern-textfield, search-field-with-icon" prefHeight="38.0" maxWidth="Infinity"/>
                    <Label text="🔍" mouseTransparent="true" style="-fx-padding: 0 0 0 10px; -fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                </StackPane>
                <!-- Status Filter Dropdown -->
                <ComboBox fx:id="statusFilterBox" promptText="All Statuses" styleClass="modern-combo-box" prefWidth="150.0" prefHeight="38.0"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="New Request" onAction="#openNewRequestOverlay" styleClass="action-btn, action-btn-warning" prefHeight="38.0"/>
                <Button text="New Event Request" onAction="#openNewEventRequestOverlay" styleClass="action-btn, action-btn-success" prefHeight="38.0"/>
            </HBox>
            
            <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="300.0">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="120.0"/>
                    <TableColumn fx:id="colReqType" text="Type" prefWidth="100.0"/>
                    <TableColumn fx:id="colPurpose" text="Purpose/Event" prefWidth="250.0"/>
                    <TableColumn fx:id="colDates" text="Authorized Dates" prefWidth="180.0"/>
                    <TableColumn fx:id="colTimes" text="Gate Times" prefWidth="130.0"/>
                    <TableColumn fx:id="colAction" text="Actions" prefWidth="150.0"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
    
    <!-- 1. Standard Request Overlay -->
    <StackPane fx:id="newRequestOverlay" visible="false" style="-fx-background-color: rgba(16, 42, 67, 0.45);" alignment="CENTER">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        <VBox spacing="0.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 15, 0, 0, 8);">
            <VBox spacing="10.0" style="-fx-padding: 20px 20px 10px 20px;">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="lblStandardRequestTitle" text="New Standard Academic BYOD Request" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#handleCloseOverlays" styleClass="overlay-close-btn"/>
                </HBox>
                <Separator/>
            </VBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox spacing="15.0" style="-fx-padding: 0px 20px 20px 20px;">
                    <Label text="I. Request Headers" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                    <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50.0"/>
                            <ColumnConstraints percentWidth="50.0"/>
                        </columnConstraints>
                        
                        <!-- Row 0: Student ID & Purpose -->
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox spacing="2.0"><Label text="Student ID:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="reqStudentIdField" promptText="e.g. 2024-00481-SR-0" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox spacing="2.0"><Label text="Purpose:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="reqPurposeField" promptText="e.g. Study classes and programming" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <!-- Row 1: Authorized Date & Venue -->
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <HBox spacing="2.0"><Label text="Authorized Date:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <DatePicker fx:id="reqStartDatePicker" styleClass="modern-datepicker" maxWidth="Infinity" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox spacing="2.0"><Label text="Venue:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="reqVenueField" promptText="e.g. Room 101 / Room 302" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <!-- Row 2: Ingress Time & Egress Time -->
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <HBox spacing="2.0"><Label text="Ingress Time:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <HBox spacing="6.0" alignment="CENTER_LEFT">
                                <ComboBox fx:id="reqIngressHour" promptText="Hr" styleClass="modern-combo-box" prefWidth="75.0" prefHeight="38.0"/>
                                <ComboBox fx:id="reqIngressMinute" promptText="Min" styleClass="modern-combo-box" prefWidth="80.0" prefHeight="38.0"/>
                                <ComboBox fx:id="reqIngressAmpm" promptText="AM/PM" styleClass="modern-combo-box" prefWidth="100.0" prefHeight="38.0"/>
                            </HBox>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <HBox spacing="2.0"><Label text="Egress Time:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <HBox spacing="6.0" alignment="CENTER_LEFT">
                                <ComboBox fx:id="reqEgressHour" promptText="Hr" styleClass="modern-combo-box" prefWidth="75.0" prefHeight="38.0"/>
                                <ComboBox fx:id="reqEgressMinute" promptText="Min" styleClass="modern-combo-box" prefWidth="80.0" prefHeight="38.0"/>
                                <ComboBox fx:id="reqEgressAmpm" promptText="AM/PM" styleClass="modern-combo-box" prefWidth="100.0" prefHeight="38.0"/>
                            </HBox>
                        </VBox>

                        <!-- Row 3: Remarks (spanning 2 columns) -->
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2">
                            <Label text="Remarks:" styleClass="form-label"/>
                            <TextField fx:id="reqRemarksField" promptText="Optional notes" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <!-- Hidden DatePicker -->
                        <DatePicker fx:id="reqEndDatePicker" visible="false" managed="false" styleClass="modern-datepicker" maxWidth="Infinity" prefHeight="38.0" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    </GridPane>
                    <Separator/>
                    <Label text="II. Devices Inline Entry Builder" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                    <VBox spacing="8.0" style="-fx-background-color: #F8FAFC; -fx-padding: 10px; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;">
                        <GridPane hgap="8.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.0"/>
                                <ColumnConstraints percentWidth="33.0"/>
                                <ColumnConstraints percentWidth="34.0"/>
                            </columnConstraints>
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="2.0">
                                    <Label text="Device Name:" styleClass="form-label"/>
                                    <Label text="*" style="-fx-text-fill: red;"/>
                                </HBox>
                                <TextField fx:id="devNameField" promptText="e.g. Laptop" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Brand:" styleClass="form-label"/>
                                <TextField fx:id="devBrandField" promptText="e.g. Apple" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Model:" styleClass="form-label"/>
                                <TextField fx:id="devModelField" promptText="e.g. Air M2" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox spacing="2.0">
                                    <Label text="Device Type:" styleClass="form-label"/>
                                    <Label text="*" style="-fx-text-fill: red;"/>
                                </HBox>
                                <ComboBox fx:id="devTypeBox" promptText="Select type" styleClass="modern-combo-box" maxWidth="Infinity" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox spacing="2.0">
                                    <Label text="Serial Number:" styleClass="form-label"/>
                                    <Label text="*" style="-fx-text-fill: red;"/>
                                </HBox>
                                <TextField fx:id="devSerialField" promptText="Enter serial number" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <Label text="Quantity:" styleClass="form-label"/>
                                <TextField fx:id="devQtyField" promptText="e.g. 1" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <Button fx:id="btnCancelDeviceNormal" text="Cancel" onAction="#cancelEditDeviceNormal" styleClass="action-btn" style="-fx-font-size: 11px; -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-text-fill: #475569;" visible="false" managed="false"/>
                            <Button fx:id="btnAddDeviceNormal" text="+ Add Device To Staging" onAction="#addStagedDeviceNormal" styleClass="action-btn, action-btn-success" style="-fx-font-size: 11px;"/>
                        </HBox>
                    </VBox>
                    <TableView fx:id="stagedNormalTable" prefHeight="110.0" styleClass="modern-table">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colStgName" text="Name" prefWidth="130.0"/>
                            <TableColumn fx:id="colStgBrand" text="Brand" prefWidth="90.0"/>
                            <TableColumn fx:id="colStgModel" text="Model" prefWidth="90.0"/>
                            <TableColumn fx:id="colStgSerial" text="Serial" prefWidth="140.0"/>
                            <TableColumn fx:id="colStgQty" text="Qty" prefWidth="50.0"/>
                            <TableColumn fx:id="colStgType" text="Type" prefWidth="110.0"/>
                            <TableColumn fx:id="colStgAction" text="Actions" prefWidth="120.0"/>
                        </columns>
                    </TableView>
                    <Separator/>
                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                        <Button text="Cancel" onAction="#handleCloseOverlays" styleClass="action-btn" prefHeight="38.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569;"/>
                        <Button fx:id="btnMakeNewRequestNormal" text="Make New Request" onAction="#handleMakeNewRequestNormal" styleClass="action-btn, action-btn-success" prefHeight="38.0" visible="false" managed="false"/>
                        <Button fx:id="btnSaveRequestNormal" text="Submit Request" onAction="#handleSaveRequestNormal" styleClass="action-btn, action-btn-primary" prefHeight="38.0"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>

    <!-- 2. Event Request Overlay -->
    <StackPane fx:id="newEventRequestOverlay" visible="false" style="-fx-background-color: rgba(16, 42, 67, 0.45);" alignment="CENTER">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        <VBox spacing="0.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 15, 0, 0, 8);">
            <VBox spacing="10.0" style="-fx-padding: 20px 20px 10px 20px;">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="lblEventRequestTitle" text="New Event BYOD Access Request" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#handleCloseOverlays" styleClass="overlay-close-btn"/>
                </HBox>
                <Separator/>
            </VBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox spacing="15.0" style="-fx-padding: 0px 20px 20px 20px;">
                    <Label text="I. Request Headers" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                    <GridPane hgap="15.0" vgap="12.0">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50.0"/>
                            <ColumnConstraints percentWidth="50.0"/>
                        </columnConstraints>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <HBox spacing="2.0"><Label text="Student ID:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="evtStudentIdField" promptText="e.g. 2024-00481-SR-0" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <HBox spacing="2.0"><Label text="Event Name:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="evtEventNameField" promptText="e.g. Tech Fair 2026" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>

                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <HBox spacing="2.0"><Label text="Organization:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="evtOrgField" promptText="e.g. ACM Student Chapter" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>

                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <HBox spacing="2.0"><Label text="Responsible Person:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="evtRespPersonField" promptText="e.g. Prof. Smith" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                            <HBox spacing="2.0"><Label text="Purpose:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="evtPurposeField" promptText="e.g. Exhibition and prototype testing" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>

                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <HBox spacing="2.0"><Label text="Venue:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <TextField fx:id="evtVenueField" promptText="e.g. Room 101" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                            <HBox spacing="2.0"><Label text="Start Date:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <DatePicker fx:id="evtStartDatePicker" styleClass="modern-datepicker" maxWidth="Infinity" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <HBox spacing="2.0"><Label text="End Date:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <DatePicker fx:id="evtEndDatePicker" styleClass="modern-datepicker" maxWidth="Infinity" prefHeight="38.0"/>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="4">
                            <HBox spacing="2.0"><Label text="Ingress Time:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <HBox spacing="6.0" alignment="CENTER_LEFT">
                                <ComboBox fx:id="evtIngressHour" promptText="Hr" styleClass="modern-combo-box" prefWidth="75.0" prefHeight="38.0"/>
                                <ComboBox fx:id="evtIngressMinute" promptText="Min" styleClass="modern-combo-box" prefWidth="80.0" prefHeight="38.0"/>
                                <ComboBox fx:id="evtIngressAmpm" promptText="AM/PM" styleClass="modern-combo-box" prefWidth="100.0" prefHeight="38.0"/>
                            </HBox>
                        </VBox>
                        
                        <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <HBox spacing="2.0"><Label text="Egress Time:" styleClass="form-label"/><Label text="*" style="-fx-text-fill: red;"/></HBox>
                            <HBox spacing="6.0" alignment="CENTER_LEFT">
                                <ComboBox fx:id="evtEgressHour" promptText="Hr" styleClass="modern-combo-box" prefWidth="75.0" prefHeight="38.0"/>
                                <ComboBox fx:id="evtEgressMinute" promptText="Min" styleClass="modern-combo-box" prefWidth="80.0" prefHeight="38.0"/>
                                <ComboBox fx:id="evtEgressAmpm" promptText="AM/PM" styleClass="modern-combo-box" prefWidth="100.0" prefHeight="38.0"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2">
                            <Label text="Remarks:" styleClass="form-label"/>
                            <TextField fx:id="evtRemarksField" promptText="Optional notes" styleClass="modern-textfield" prefHeight="38.0"/>
                        </VBox>
                    </GridPane>
                    <Separator/>
                    <Label text="II. Devices Inline Entry Builder" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                    <VBox spacing="8.0" style="-fx-background-color: #F8FAFC; -fx-padding: 10px; -fx-border-color: #E2E8F0; -fx-border-radius: 8; -fx-background-radius: 8;">
                        <GridPane hgap="8.0" vgap="8.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="33.0"/>
                                <ColumnConstraints percentWidth="33.0"/>
                                <ColumnConstraints percentWidth="34.0"/>
                            </columnConstraints>
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <HBox spacing="2.0">
                                    <Label text="Device Name:" styleClass="form-label"/>
                                    <Label text="*" style="-fx-text-fill: red;"/>
                                </HBox>
                                <TextField fx:id="evtDevNameField" promptText="e.g. Project Kit" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Brand:" styleClass="form-label"/>
                                <TextField fx:id="evtDevBrandField" promptText="e.g. Generic" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                                <Label text="Model:" styleClass="form-label"/>
                                <TextField fx:id="evtDevModelField" promptText="e.g. Custom" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <HBox spacing="2.0">
                                    <Label text="Device Type:" styleClass="form-label"/>
                                    <Label text="*" style="-fx-text-fill: red;"/>
                                </HBox>
                                <ComboBox fx:id="evtDevTypeBox" promptText="Select type" styleClass="modern-combo-box" maxWidth="Infinity" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <HBox spacing="2.0">
                                    <Label text="Serial Number:" styleClass="form-label"/>
                                    <Label text="*" style="-fx-text-fill: red;"/>
                                </HBox>
                                <TextField fx:id="evtDevSerialField" promptText="Enter serial number" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                            <VBox spacing="4.0" GridPane.columnIndex="2" GridPane.rowIndex="1">
                                <Label text="Quantity:" styleClass="form-label"/>
                                <TextField fx:id="evtDevQtyField" promptText="e.g. 1" styleClass="modern-textfield" prefHeight="34.0"/>
                            </VBox>
                        </GridPane>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <Button fx:id="btnCancelDeviceEvent" text="Cancel" onAction="#cancelEditDeviceEvent" styleClass="action-btn" style="-fx-font-size: 11px; -fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-text-fill: #475569;" visible="false" managed="false"/>
                            <Button fx:id="btnAddDeviceEvent" text="+ Add Device To Staging" onAction="#addStagedDeviceEvent" styleClass="action-btn, action-btn-success" style="-fx-font-size: 11px;"/>
                        </HBox>
                    </VBox>
                    <TableView fx:id="stagedEventTable" prefHeight="110.0" styleClass="modern-table">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colEvtStgName" text="Name" prefWidth="130.0"/>
                            <TableColumn fx:id="colEvtStgBrand" text="Brand" prefWidth="90.0"/>
                            <TableColumn fx:id="colEvtStgModel" text="Model" prefWidth="90.0"/>
                            <TableColumn fx:id="colEvtStgSerial" text="Serial" prefWidth="140.0"/>
                            <TableColumn fx:id="colEvtStgQty" text="Qty" prefWidth="50.0"/>
                            <TableColumn fx:id="colEvtStgType" text="Type" prefWidth="110.0"/>
                            <TableColumn fx:id="colEvtStgAction" text="Actions" prefWidth="120.0"/>
                        </columns>
                    </TableView>
                    <Separator/>
                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                        <Button text="Cancel" onAction="#handleCloseOverlays" styleClass="action-btn" prefHeight="38.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569;"/>
                        <Button fx:id="btnMakeNewRequestEvent" text="Make New Request" onAction="#handleMakeNewRequestEvent" styleClass="action-btn, action-btn-success" prefHeight="38.0" visible="false" managed="false"/>
                        <Button fx:id="btnSaveRequestEvent" text="Submit Event Request" onAction="#handleSaveRequestEvent" styleClass="action-btn, action-btn-primary" prefHeight="38.0"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </VBox>
    </StackPane>

    <!-- 3. View Devices & Review Modal Overlay (Non-movable, centred) -->
    <StackPane fx:id="reviewOverlay" visible="false" style="-fx-background-color: rgba(16, 42, 67, 0.45);" alignment="CENTER">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        <VBox spacing="0.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.15), 15, 0, 0, 8);">
            
            <VBox spacing="10.0" style="-fx-padding: 20px 20px 10px 20px;">
                <HBox alignment="CENTER_LEFT">
                    <Label fx:id="reviewTitleLabel" text="Review Access Request Devices" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#handleCloseOverlays" styleClass="overlay-close-btn"/>
                </HBox>
                <Separator/>
            </VBox>
            
            <VBox spacing="15.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 20px 20px 20px;">
                <GridPane hgap="15.0" vgap="8.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="30.0" halignment="LEFT"/>
                        <ColumnConstraints percentWidth="70.0" halignment="LEFT"/>
                    </columnConstraints>
                    <Label text="Requester ID:" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="lblReviewStudentId" text="-" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    
                    <Label text="Type:" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="lblReviewType" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Purpose / Event:" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="lblReviewPurpose" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    
                    <Label text="Venue:" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="lblReviewVenue" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                    
                    <Label text="Expected Times:" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <Label fx:id="lblReviewTimes" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Status:" style="-fx-font-weight: bold; -fx-text-fill: #64748B;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <Label fx:id="lblReviewStatus" text="-" styleClass="status-badge" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>
                
                <Label text="Device Line Items:" styleClass="form-label" style="-fx-text-fill: #0284C7;"/>
                <TableView fx:id="reviewDevicesTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colRevName" text="Device Name" prefWidth="150.0"/>
                        <TableColumn fx:id="colRevBrand" text="Brand" prefWidth="100.0"/>
                        <TableColumn fx:id="colRevModel" text="Model" prefWidth="100.0"/>
                        <TableColumn fx:id="colRevSerial" text="Serial" prefWidth="130.0"/>
                        <TableColumn fx:id="colRevQty" text="Qty" prefWidth="60.0"/>
                    </columns>
                </TableView>
                
                <Separator/>
                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <!-- Action buttons dynamically shown for pending requests -->
                    <Button fx:id="btnReturn" text="Return Request" onAction="#handleReturnRequest" styleClass="action-btn, action-btn-warning" prefHeight="36.0"/>
                    <Button fx:id="btnReject" text="Reject Request" onAction="#handleRejectRequest" styleClass="action-btn, action-btn-danger" prefHeight="36.0"/>
                    <Button fx:id="btnApprove" text="Approve Request" onAction="#handleApproveRequest" styleClass="action-btn, action-btn-success" prefHeight="36.0"/>
                    <Button fx:id="btnCancelRequest" text="Cancel Request" onAction="#handleCancelRequest" styleClass="action-btn, action-btn-danger" prefHeight="36.0"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>
</StackPane>
