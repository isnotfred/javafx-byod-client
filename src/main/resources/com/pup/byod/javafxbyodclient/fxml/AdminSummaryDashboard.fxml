<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.AdminSummaryDashboardController"
      spacing="20.0" styleClass="dashboard-container" VBox.vgrow="ALWAYS">
      
    <!-- Header Row -->
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <VBox spacing="2.0">
            <Label text="System Summary Dashboard" styleClass="dashboard-title"/>
            <Label text="BYOD Central Administrator Panel" styleClass="dashboard-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh Stats" onAction="#refreshStats" styleClass="refresh-btn"/>
    </HBox>
    
    <Separator/>
    
    <!-- Cards Row -->
    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <!-- Card 1: Active Students -->
        <VBox styleClass="card">
            <Label text="Active Students" styleClass="card-title"/>
            <Label fx:id="activeStudentsLabel" text="0" styleClass="card-value"/>
        </VBox>
        
        <!-- Card 2: Registered Devices -->
        <VBox styleClass="card">
            <Label text="Registered Devices" styleClass="card-title"/>
            <Label fx:id="registeredDevicesLabel" text="0" styleClass="card-value"/>
        </VBox>
        
        <!-- Card 3: Pending Approvals -->
        <VBox styleClass="card">
            <Label text="Pending Approvals" styleClass="card-title"/>
            <Label fx:id="pendingApprovalsLabel" text="0" styleClass="card-value"/>
        </VBox>
        
        <!-- Card 4: Devices On Campus -->
        <VBox styleClass="card">
            <Label text="Devices On-Campus" styleClass="card-title"/>
            <Label fx:id="devicesOnCampusLabel" text="0" styleClass="card-value"/>
        </VBox>
    </HBox>
    
    <Label text="Quick Access Shortcuts" styleClass="section-title"/>
    
    <!-- Quick Access Buttons -->
    <FlowPane hgap="15.0" vgap="15.0" prefWrapLength="800.0">
        <Button text="📂 Student Registry" onAction="#goToStudents" prefWidth="180.0" styleClass="quick-btn"/>
        <Button text="💻 Device Registry" onAction="#goToDevices" prefWidth="180.0" styleClass="quick-btn"/>
        <Button text="⏳ Review Approvals" onAction="#goToApprovals" prefWidth="180.0" styleClass="quick-btn"/>
        <Button text="📊 Analytical Reports" onAction="#goToReports" prefWidth="180.0" styleClass="quick-btn"/>
    </FlowPane>
    
</VBox>
