<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" 
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 0;" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.AdminSummaryDashboardController">
            
    <VBox spacing="24.0" styleClass="admin-dashboard-container" VBox.vgrow="ALWAYS">
        
        <!-- Hero Welcome Banner -->
        <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="15.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label fx:id="welcomeLabel" text="Welcome back!" styleClass="welcome-title"/>
                <Label text="BYOD Central Administrator Panel — Manage and monitor student registrations and devices." styleClass="welcome-subtitle"/>
            </VBox>
            <Button text="Refresh Stats" onAction="#refreshStats" styleClass="refresh-btn"/>
        </HBox>
        
        <!-- Cards Row -->
        <HBox spacing="24.0" alignment="CENTER_LEFT" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <!-- Card 1: Active Students -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Active Students" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-blue">
                        <!-- Single User SVG (Cleaned) -->
                        <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                 styleClass="stat-icon-blue-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="activeStudentsLabel" text="0" styleClass="stat-value, stat-value-blue"/>
            </VBox>
            
            <!-- Card 2: Registered Devices -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Registered Devices" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-purple">
                        <!-- Laptop SVG -->
                        <SVGPath content="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zM4 6h16v10H4V6z" 
                                 styleClass="stat-icon-purple-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="registeredDevicesLabel" text="0" styleClass="stat-value, stat-value-purple"/>
            </VBox>
            
            <!-- Card 3: Pending Approvals -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Pending Approvals" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-yellow">
                        <!-- Clean Clock SVG -->
                        <SVGPath content="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8zm.5-13H11v6l5.2 3.1.8-1.3-4.5-2.7V7z" 
                                 styleClass="stat-icon-yellow-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="pendingApprovalsLabel" text="0" styleClass="stat-value, stat-value-orange"/>
            </VBox>
            
            <!-- Card 4: Devices On Campus (Gold Border, Lighter Yellow Container) -->
            <VBox styleClass="stat-card-gold" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Devices On-Campus" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-light-yellow">
                        <!-- Signal Bars SVG -->
                        <SVGPath content="M3 17h2v3H3zm4-7h2v10H7zm4-5h2v15h-2zm4 8h2v7h-2zm4-4h2v11h-2z" 
                                 styleClass="stat-icon-yellow-svg"/>
                </StackPane>
            </HBox>
            <Label fx:id="devicesOnCampusLabel" text="0" styleClass="stat-value, stat-value-gold"/>
        </VBox>
        </HBox>
        
        <Label text="Quick Access Management Panels" styleClass="section-title"/>
        <!-- Quick Access Buttons (2x2 Stack Layout via responsive GridPane) -->
        <GridPane hgap="24.0" vgap="24.0" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" percentWidth="50"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" minHeight="10.0"/>
                <RowConstraints vgrow="SOMETIMES" minHeight="10.0"/>
            </rowConstraints>
            
            <!-- Student Registry -->
            <Button onAction="#goToStudents" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <!-- Clean Sheet List SVG -->
                            <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Registry Management" styleClass="shortcut-title"/>
                            <Label text="Manage student profiles and registration status" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- Device Registry -->
            <Button onAction="#goToDevices" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <!-- Monitor SVG -->
                            <SVGPath content="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7l-2 3v1h8v-1l-2-3h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Event Requests" styleClass="shortcut-title"/>
                            <Label text="Manage event clearance requests and temporary device authorization" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- Review Approvals -->
            <Button onAction="#goToApprovals" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane alignment="TOP_RIGHT">
                            <StackPane styleClass="shortcut-icon-container">
                                <!-- Shield Check/Circle Check SVG -->
                                <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                         styleClass="shortcut-icon"/>
                            </StackPane>
                            <Label fx:id="pendingApprovalsBadge" text="0" styleClass="shortcut-badge"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Review Approvals" styleClass="shortcut-title"/>
                            <Label text="Approve or reject pending BYOD registration requests" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- Analytical Reports -->
            <Button onAction="#goToReports" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <!-- Bar Chart SVG -->
                            <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Analytical Reports" styleClass="shortcut-title"/>
                            <Label text="View campus gate logs and analytical reports" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
        </GridPane>
        
    </VBox>
</ScrollPane>
