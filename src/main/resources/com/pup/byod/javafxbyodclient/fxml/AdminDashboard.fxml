<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.AdminDashboardController"
            prefWidth="1000.0" prefHeight="700.0">
            
    <fx:define>
        <ToggleGroup fx:id="sidebarGroup"/>
    </fx:define>
            
    <!-- Left Sidebar -->
    <left>
        <VBox styleClass="sidebar-container" spacing="10.0">
            
            <HBox styleClass="sidebar-logo-container" spacing="12.0" alignment="CENTER_LEFT">
                <ImageView fitHeight="32.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/BYOD_Logo.png"/>
                    </image>
                </ImageView>
                <VBox spacing="3.0" alignment="CENTER_LEFT">
                    <Label text="BYOD MANAGEMENT" styleClass="sidebar-title-text" style="-fx-font-size: 13px;"/>
                    <Label fx:id="roleBadge" styleClass="role-badge" text="ROLE"/>
                </VBox>
            </HBox>
            
            <Separator style="-fx-opacity: 0.15;"/>
            
            <!-- Sidebar Buttons with Icons -->
            <ToggleButton text="Dashboard" onAction="#showSummaryDashboard" toggleGroup="$sidebarGroup" selected="true" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M2 2h8v8H2V2zm10 0h8v8h-8V2zM2 12h8v8H2v-8zm10 0h8v8h-8v-8z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Registry Management" onAction="#showRegistryManagement" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M12 2C6.48 2 2 4.02 2 6.5v11c0 2.48 4.48 4.5 10 4.5s10-2.02 10-4.5v-11C22 4.02 17.52 2 12 2zm0 16c-4.42 0-8-1.34-8-3V13.5c1.86 1 4.77 1.5 8 1.5s6.14-.5 8-1.5V15c0 1.66-3.58 3-8 3zm0-5c-4.42 0-8-1.34-8-3V8.5c1.86 1 4.77 1.5 8 1.5s6.14-.5 8-1.5V10c0 1.66-3.58 3-8 3zm0-5c-4.42 0-8-1.34-8-3S7.58 2 12 2s8 1.34 8 3-3.58 3-8 3z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Pending Approvals" onAction="#showPendingApprovals" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Event Requests" onAction="#showEventRequests" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zm-2-7h-4v4h4v-4z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="On-Campus Devices" onAction="#showActiveDevices" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Analytical Reports" onAction="#showReports" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 10h2v7H7zm4-3h2v10h-2zm4 6h2v4h-2z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="System Audit Logs" onAction="#showSystemAuditLogs" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Profile Management" onAction="#showProfile" toggleGroup="$sidebarGroup" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="sidebar-icon"/>
                </graphic>
            </ToggleButton>
            
            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-opacity: 0.15;"/>
            <Button text="Logout" onAction="#handleLogout" prefWidth="200.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" styleClass="sidebar-icon"/>
                </graphic>
            </Button>
        </VBox>
    </left>
    
    <!-- Right Content Area -->
    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
            <Label text="Please select an option from the sidebar."/>
        </StackPane>
    </center>
    
</BorderPane>
