<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pup.byod.javafxbyodclient.controller.LogsScreenController"
           HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
           
    <!-- Main Content Layer -->
    <VBox spacing="15.0">
        <padding>
            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
        </padding>
        
        <!-- Hero Header -->
        <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="Gate Transaction Logs" styleClass="welcome-title"/>
            <Label text="Monitor device check-ins and check-outs at security gates in real-time." styleClass="welcome-subtitle"/>
        </VBox>
        
        <!-- Logs Card -->
        <VBox spacing="12.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <!-- Search Bar -->
                <StackPane alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="350.0">
                    <TextField fx:id="searchField" promptText="Search by Student ID, Name, or Device SN" styleClass="modern-textfield, search-field-with-icon" prefHeight="38.0" maxWidth="Infinity"/>
                    <Label text="🔍" mouseTransparent="true" style="-fx-padding: 0 0 0 10px; -fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
                </StackPane>
                
                <!-- Period Filter -->
                <Label text="Filter Period:" styleClass="form-label" style="-fx-padding: 0 0 0 15px; -fx-font-weight: bold;"/>
                <ComboBox fx:id="filterPeriodComboBox" prefWidth="180.0" prefHeight="38.0" styleClass="modern-combo-box"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Export to Excel" onAction="#handleExportExcel" styleClass="action-btn, action-btn-success" prefHeight="38.0"/>
            </HBox>
            
            <TableView fx:id="logsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="300.0">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="130.0"/>
                    <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="120.0"/>
                    <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="180.0"/>
                    <TableColumn fx:id="colDeviceName" text="Device" prefWidth="140.0"/>
                    <TableColumn fx:id="colSerial" text="Serial Number" prefWidth="140.0"/>
                    <TableColumn fx:id="colIngress" text="Checked-In" prefWidth="110.0"/>
                    <TableColumn fx:id="colEgress" text="Checked-Out" prefWidth="110.0"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
</StackPane>
