<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@../css/active_devices.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ActiveDevicesInsideCampusScreenController"
      spacing="20.0" styleClass="module-container" VBox.vgrow="ALWAYS">
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="Active Campus Devices Overview (Admin view)" styleClass="module-header"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refresh Registry" onAction="#loadStatus" styleClass="action-btn, action-btn-secondary"/>
    </HBox>
    
    <TableView fx:id="statusTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="Device ID" prefWidth="70.0"/>
            <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="120.0"/>
            <TableColumn fx:id="colName" text="Device Name" prefWidth="150.0"/>
            <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="150.0"/>
            <TableColumn fx:id="colStatus" text="Campus Status" prefWidth="100.0"/>
            <TableColumn fx:id="colLastTime" text="Last Active Time" prefWidth="180.0"/>
        </columns>
    </TableView>
</VBox>
