<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.TemporaryEventDeviceScreenController"
      spacing="15.0" HBox.hgrow="ALWAYS">
    
    <!-- Left Panel: Event Info Form -->
    <VBox spacing="10.0" prefWidth="350.0">
        <Label text="New Event Request Wizard" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10.0" vgap="8.0">
            <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="studentIdField" promptText="e.g. 2021-10023" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            
            <Label text="Event Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="eventNameField" promptText="e.g. Hackathon" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            
            <Label text="Organization:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <TextField fx:id="organizationField" promptText="e.g. IT Society" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            
            <Label text="Supervisor:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="responsiblePersonField" promptText="e.g. Prof. Doe" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            
            <Label text="Purpose:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <TextField fx:id="purposeField" promptText="e.g. Exhibition" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
            
            <Label text="Doc Ref:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <TextField fx:id="docRefField" promptText="e.g. REF-001" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
            
            <Label text="Doc Type:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <ComboBox fx:id="docTypeBox" promptText="Select Document" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
            
            <Label text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
            <DatePicker fx:id="startDatePicker" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
            
            <Label text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="8"/>
            <DatePicker fx:id="endDatePicker" prefWidth="180.0" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
        </GridPane>
        
        <Button text="Submit Request" onAction="#handleSubmitRequest" prefWidth="250.0" style="-fx-font-weight: bold; -fx-text-fill: green;"/>
    </VBox>
    
    <Separator orientation="VERTICAL"/>
    
    <!-- Right Panel: Device List Configuration -->
    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
        <Label text="Line Items (Devices to authorize)" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        
        <GridPane hgap="10.0" vgap="8.0">
            <Label text="Device Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="deviceNameField" promptText="e.g. Prototype Board" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            
            <Label text="Brand:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            <TextField fx:id="brandField" promptText="e.g. Custom" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
            
            <Label text="Model:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="modelField" promptText="e.g. Pi-4" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            
            <Label text="Serial No:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="serialNumberField" promptText="Optional SN" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
            
            <Label text="Device Type:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="deviceTypeBox" promptText="Category" prefWidth="150.0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            
            <Button text="Add Item" onAction="#handleAddItem" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="120.0"/>
        </GridPane>
        
        <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDevName" text="Device Name" prefWidth="200.0"/>
                <TableColumn fx:id="colDevSN" text="Serial Number" prefWidth="150.0"/>
                <TableColumn fx:id="colDevType" text="Device Type" prefWidth="150.0"/>
            </columns>
        </TableView>
    </VBox>
</HBox>
