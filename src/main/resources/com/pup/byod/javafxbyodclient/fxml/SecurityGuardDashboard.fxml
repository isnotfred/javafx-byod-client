<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.SecurityGuardDashboardController"
            prefWidth="1000.0" prefHeight="700.0">
            
    <fx:define>
        <ToggleGroup fx:id="guardNavGroup"/>
    </fx:define>
            
    <!-- Top Header Bar -->
    <top>
        <HBox spacing="15.0" alignment="CENTER_LEFT" styleClass="header-bar" style="-fx-background-color: #102A43; -fx-padding: 10px 20px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 8, 0, 0, 2);">
            <ImageView fitHeight="32.0" pickOnBounds="true" preserveRatio="true">
                <image>
                    <Image url="@../images/BYOD_Logo.png"/>
                </image>
            </ImageView>
            <VBox spacing="2.0" alignment="CENTER_LEFT">
                <Label text="BYOD MANAGEMENT SYSTEM" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;"/>
                <Label fx:id="roleBadge" text="GUARD" styleClass="role-badge, role-badge-guard" style="-fx-font-size: 10px; -fx-padding: 2px 6px;"/>
            </VBox>
            
            <!-- Navigation Tabs for Guard: Requests & Events -->
            <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 0 0 0 40px;">
                <ToggleButton fx:id="requestsBtn" text="Requests" toggleGroup="$guardNavGroup" selected="true" onAction="#showGateScan"
                              styleClass="guard-nav-btn"/>
                <ToggleButton fx:id="eventsBtn" text="Events" toggleGroup="$guardNavGroup" onAction="#showEventsScreen"
                              styleClass="guard-nav-btn"/>
            </HBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="action-btn" style="-fx-background-color: #EF4444; -fx-text-fill: #FFFFFF; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 6px 12px; -fx-border-radius: 6px; -fx-background-radius: 6px;">
                <graphic>
                    <SVGPath content="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" fill="white"/>
                </graphic>
            </Button>
        </HBox>
    </top>
    
    <!-- Right/Center Content Area (loads Ingress/Egress Screen) -->
    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
        </StackPane>
    </center>
    
</BorderPane>
