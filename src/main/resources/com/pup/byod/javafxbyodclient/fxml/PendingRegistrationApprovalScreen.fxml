<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@../css/pending_approval.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.PendingRegistrationApprovalScreenController"
      spacing="20.0" styleClass="module-container" VBox.vgrow="ALWAYS">
    
    <Label text="Registration Approval Queue" styleClass="module-header"/>
    
    <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50.0"/>
            <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="150.0"/>
            <TableColumn fx:id="colDeviceName" text="Device Name" prefWidth="150.0"/>
            <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="150.0"/>
            <TableColumn fx:id="colPurpose" text="Purpose" prefWidth="150.0"/>
        </columns>
    </TableView>
    
    <VBox spacing="8.0" styleClass="module-card">
        <Label text="Rejection Remarks (Mandatory if rejecting):" styleClass="form-label"/>
        <TextArea fx:id="remarksArea" promptText="Enter reasons for rejection here..." styleClass="modern-textarea" prefHeight="80.0"/>
        
        <HBox spacing="12.0" alignment="CENTER_RIGHT">
            <Button text="Reject" onAction="#handleReject" styleClass="action-btn, action-btn-danger" prefWidth="120.0"/>
            <Button text="Approve" onAction="#handleApprove" styleClass="action-btn, action-btn-success" prefWidth="120.0"/>
        </HBox>
    </VBox>
</VBox>
