<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.PendingRegistrationApprovalScreenController"
      spacing="10.0" VBox.vgrow="ALWAYS">
    
    <Label text="Registration Approval Queue" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <TableView fx:id="pendingTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50.0"/>
            <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="150.0"/>
            <TableColumn fx:id="colDeviceName" text="Device Name" prefWidth="150.0"/>
            <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="150.0"/>
            <TableColumn fx:id="colPurpose" text="Purpose" prefWidth="150.0"/>
        </columns>
    </TableView>
    
    <VBox spacing="5.0">
        <Label text="Rejection Remarks (Mandatory if rejecting):"/>
        <TextArea fx:id="remarksArea" promptText="Enter reasons for rejection here..." prefHeight="80.0"/>
    </VBox>
    
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Approve" onAction="#handleApprove" style="-fx-text-fill: green; -fx-font-weight: bold;" prefWidth="100.0"/>
        <Button text="Reject" onAction="#handleReject" style="-fx-text-fill: red;" prefWidth="100.0"/>
    </HBox>
</VBox>
