<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.SystemConfigurationScreenController"
      spacing="15.0" VBox.vgrow="ALWAYS"
      stylesheets="@../css/admin_dashboard_styles.css">
      
    <padding>
        <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
    </padding>
    
    <!-- Hero Header Banner -->
    <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label text="System Configuration &amp; Policies" styleClass="welcome-title"/>
        <Label text="Adjust global rules, override allowances, and device limitation parameters of the BYOD network." styleClass="welcome-subtitle"/>
    </VBox>
    
    <!-- Main Content Split Layout -->
    <HBox spacing="15.0" VBox.vgrow="ALWAYS" alignment="TOP_CENTER" maxWidth="Infinity">
        
        <!-- Left Column: Settings Table Card -->
        <VBox spacing="12.0" HBox.hgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
            
            <Label text="Global Parameters Registry" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
            
            <TableView fx:id="settingsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="300.0">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colKey" text="Setting Key" prefWidth="180.0"/>
                    <TableColumn fx:id="colValue" text="Value" prefWidth="150.0"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="270.0"/>
                </columns>
            </TableView>
        </VBox>
        
        <!-- Right Column: Edit Form Card (Width: 320px) -->
        <VBox spacing="15.0" prefWidth="320.0" minWidth="320.0" maxWidth="320.0"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
            
            <Label text="Modify System Setting" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
            <Separator/>
            
            <VBox spacing="5.0">
                <Label text="Setting Key:" styleClass="form-label"/>
                <Label fx:id="keyLabel" text="(Select a setting)" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0284C7;"/>
            </VBox>
            
            <VBox spacing="5.0">
                <Label text="Setting Value:" styleClass="form-label"/>
                <TextField fx:id="valueField" promptText="Enter value..." styleClass="modern-textfield" prefHeight="38.0"/>
            </VBox>
            
            <VBox spacing="5.0">
                <Label text="Description:" styleClass="form-label"/>
                <Label fx:id="descriptionLabel" wrapText="true" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 13px; -fx-text-fill: #475569;"/>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
            <Separator/>
            
            <Button fx:id="saveButton" text="Save Changes" onAction="#handleSaveSetting" maxWidth="Infinity" prefHeight="40.0" styleClass="action-btn, action-btn-success"/>
        </VBox>
        
    </HBox>
    
</VBox>
