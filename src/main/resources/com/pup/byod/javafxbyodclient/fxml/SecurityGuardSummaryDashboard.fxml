<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" 
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 0;" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.SecurityGuardSummaryDashboardController">
            
    <VBox spacing="24.0" styleClass="admin-dashboard-container" VBox.vgrow="ALWAYS">
        
        <!-- Hero Welcome Banner -->
        <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="15.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label fx:id="welcomeLabel" text="Welcome back, Guard!" styleClass="welcome-title"/>
                <Label text="BYOD Campus Security Gate Control — Verify registered student and temporary event devices." styleClass="welcome-subtitle"/>
            </VBox>
            <Button text="Refresh Stats" onAction="#refreshStats" styleClass="refresh-btn"/>
        </HBox>
        
        <!-- Cards Row -->
        <HBox spacing="24.0" alignment="CENTER_LEFT" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <!-- Card 1: Devices On Campus (Gold) -->
            <VBox styleClass="stat-card-gold" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Devices On-Campus" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-light-yellow">
                        <SVGPath content="M3 17h2v3H3zm4-7h2v10H7zm4-5h2v15h-2zm4 8h2v7h-2zm4-4h2v11h-2z" 
                                 styleClass="stat-icon-yellow-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="devicesOnCampusLabel" text="0" styleClass="stat-value, stat-value-gold"/>
            </VBox>
            
            <!-- Card 2: Active Events -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Active Events" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-blue">
                        <SVGPath content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z" 
                                 styleClass="stat-icon-blue-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="activeEventsLabel" text="0" styleClass="stat-value, stat-value-blue"/>
            </VBox>
            
            <!-- Card 3: Approved Devices -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Approved Devices" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-purple">
                        <SVGPath content="M20 18c1.1 0 1.99-.9 1.99-2L22 6c0-1.1-.9-2-2-2H4c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2H0v2h24v-2h-4zM4 6h16v10H4V6z" 
                                 styleClass="stat-icon-purple-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="totalApprovedDevicesLabel" text="0" styleClass="stat-value, stat-value-purple"/>
            </VBox>
        </HBox>
        
        <Label text="Quick Access Gate Controls" styleClass="section-title"/>
        
        <!-- Quick Access Buttons (2x2 Stack Layout via responsive GridPane) -->
        <GridPane hgap="24.0" vgap="24.0" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" percentWidth="50"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="100.0" percentWidth="50"/>
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" minHeight="10.0"/>
                <RowConstraints vgrow="SOMETIMES" minHeight="10.0"/>
            </rowConstraints>
            
            <!-- Ingress/Egress -->
            <Button onAction="#goToGateScan" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M3 3v18h18V3H3zm16 16H5V5h14v14zM7 7h10v2H7zm0 4h10v2H7zm0 4h7v2H7z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Ingress/Egress" styleClass="shortcut-title"/>
                            <Label text="Log student devices entering and exiting campus" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- Quick Registration -->
            <Button onAction="#goToQuickRegister" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Quick Registration" styleClass="shortcut-title"/>
                            <Label text="Quickly register incoming temporary devices" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- Event Device Verification -->
            <Button onAction="#goToEventScanner" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M19 4h-1V2h-2v2H8V2H6v2H5c-1.11 0-1.99.9-1.99 2L3 20c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Event Devices" styleClass="shortcut-title"/>
                            <Label text="Verify devices for specific campus events" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- On-Campus Devices -->
            <Button onAction="#goToActiveDevices" maxWidth="Infinity" styleClass="shortcut-card" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="On-Campus Devices" styleClass="shortcut-title"/>
                            <Label text="View all active devices currently in the campus" styleClass="shortcut-desc"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
        </GridPane>
        
    </VBox>
</ScrollPane>
