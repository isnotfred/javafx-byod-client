<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.StudentManagementScreenController"
      spacing="15.0" HBox.hgrow="ALWAYS">
    
    <!-- Left Side: Student List & Search -->
    <VBox spacing="10.0" HBox.hgrow="ALWAYS" prefWidth="600.0">
        <Label text="Student Directory" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        
        <HBox spacing="10.0">
            <TextField fx:id="searchField" promptText="Search student ID or Name" prefWidth="250.0"/>
            <Button text="Search" onAction="#handleSearch"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Import CSV" onAction="#handleImportCsv" style="-fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Button text="Deactivate" onAction="#handleDeactivate" style="-fx-text-fill: red;"/>
        </HBox>
        
        <TableView fx:id="studentTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="Student ID" prefWidth="120.0"/>
                <TableColumn fx:id="colName" text="Full Name" prefWidth="200.0"/>
                <TableColumn fx:id="colCourse" text="Course &amp; Section" prefWidth="150.0"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="80.0"/>
            </columns>
        </TableView>
    </VBox>
    
    <Separator orientation="VERTICAL"/>
    
    <!-- Right Side: Add Student Form -->
    <VBox spacing="15.0" prefWidth="300.0">
        <Label text="Add Student Record" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        
        <VBox spacing="5.0">
            <Label text="Student ID:"/>
            <TextField fx:id="studentIdField" promptText="e.g. 2021-10023"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="First Name:"/>
            <TextField fx:id="firstNameField" promptText="e.g. Juan"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Last Name:"/>
            <TextField fx:id="lastNameField" promptText="e.g. Dela Cruz"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Course &amp; Year Level:"/>
            <TextField fx:id="courseYearLevelField" promptText="e.g. BSIT 3-1"/>
        </VBox>
        
        <Button text="Create Student" onAction="#handleAddStudent" prefWidth="200.0" style="-fx-font-weight: bold;"/>
    </VBox>
</HBox>
