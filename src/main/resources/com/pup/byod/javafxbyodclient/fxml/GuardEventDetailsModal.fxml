<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" prefWidth="760.0" prefHeight="480.0" 
      style="-fx-background-color: #FFFFFF; -fx-padding: 20px; -fx-border-color: #CBD5E1; -fx-border-width: 2px; -fx-border-radius: 12px; -fx-background-radius: 12px;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.GuardEventDetailsModalController"
      stylesheets="@../css/admin_dashboard_styles.css">
      
    <!-- Header Area -->
    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Label text="Event Access Specifications" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Read-only Device Specifications" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-text-fill: #64748B;"/>
    </HBox>
    
    <Separator/>

    <!-- Event Meta Details Grid -->
    <GridPane hgap="20.0" vgap="6.0" style="-fx-background-color: #F8FAFC; -fx-padding: 12px; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 8px; -fx-background-radius: 8px;">
        <columnConstraints>
            <ColumnConstraints minWidth="120.0" prefWidth="130.0" />
            <ColumnConstraints hgrow="ALWAYS" />
            <ColumnConstraints minWidth="120.0" prefWidth="130.0" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        
        <Label text="Event Name:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Label fx:id="lblEventName" text="-" style="-fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="Venue:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Label fx:id="lblVenue" text="-" style="-fx-text-fill: #0F172A;" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        
        <Label text="Organization:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="lblOrg" text="-" style="-fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Coordinator:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <Label fx:id="lblCoordinator" text="-" style="-fx-text-fill: #0F172A;" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        
        <Label text="Expected Time:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <Label fx:id="lblTime" text="-" style="-fx-text-fill: #0F172A;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Purpose:" style="-fx-font-weight: bold; -fx-text-fill: #475569;" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
        <Label fx:id="lblPurpose" text="-" style="-fx-text-fill: #0F172A;" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
    </GridPane>
    
    <!-- Registered Devices Table (No Checkbox) -->
    <TableView fx:id="devicesTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colDevName" text="Device Name" prefWidth="180.0"/>
            <TableColumn fx:id="colDevBrand" text="Brand" prefWidth="110.0"/>
            <TableColumn fx:id="colDevModel" text="Model" prefWidth="110.0"/>
            <TableColumn fx:id="colDevSerial" text="Serial Number" prefWidth="180.0"/>
            <TableColumn fx:id="colDevQuantity" text="Qty" prefWidth="70.0" style="-fx-alignment: CENTER;"/>
        </columns>
    </TableView>
    
    <Separator/>
    
    <!-- Footer Button Bar -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Close Window" onAction="#handleClose" prefHeight="38.0" prefWidth="130.0" styleClass="action-btn" style="-fx-background-color: #38BDF8; -fx-text-fill: #0F172A; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
    
</VBox>
