<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ReportsScreenController"
      spacing="10.0" VBox.vgrow="ALWAYS">
    
    <Label text="Analytical Reports &amp; Incident Logs" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="Report Type:"/>
        <ComboBox fx:id="reportTypeBox" promptText="Select Report Type" prefWidth="200.0"/>
        
        <Label text="From:"/>
        <DatePicker fx:id="startDatePicker"/>
        
        <Label text="To:"/>
        <DatePicker fx:id="endDatePicker"/>
        
        <Button text="Generate Report" onAction="#handleGenerateReport"/>
    </HBox>
    
    <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS">
        <!-- Columns are generated dynamically in the controller -->
    </TableView>
</VBox>
