<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox stylesheets="@../css/reports.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ReportsScreenController"
      spacing="20.0" styleClass="module-container" VBox.vgrow="ALWAYS">
    
    <Label text="Analytical Reports &amp; Incident Logs" styleClass="module-header"/>
    
    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <Label text="Report Type:" styleClass="form-label"/>
        <ComboBox fx:id="reportTypeBox" promptText="Select Report Type" prefWidth="200.0" styleClass="modern-combo-box"/>
        
        <Label text="From:" styleClass="form-label"/>
        <DatePicker fx:id="startDatePicker" styleClass="modern-date-picker"/>
        
        <Label text="To:" styleClass="form-label"/>
        <DatePicker fx:id="endDatePicker" styleClass="modern-date-picker"/>
        
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Generate Report" onAction="#handleGenerateReport" styleClass="action-btn, action-btn-primary"/>
    </HBox>
    
    <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <!-- Columns are generated dynamically in the controller -->
    </TableView>
</VBox>
