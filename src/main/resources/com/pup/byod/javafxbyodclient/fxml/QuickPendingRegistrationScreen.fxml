<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.QuickPendingRegistrationScreenController"
      spacing="15.0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
    
    <Label text="Quick Device Registration (On-the-fly)" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    
    <GridPane hgap="15.0" vgap="10.0" alignment="CENTER" maxWidth="500.0">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="120.0"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
        </columnConstraints>
        
        <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="studentIdField" promptText="e.g. 2021-10023" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <Label text="Device Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="deviceNameField" promptText="e.g. Laptop" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Brand:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="brandField" promptText="e.g. Asus" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Model:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="modelField" promptText="e.g. Zenbook" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        
        <Label text="Serial Number:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="serialNumberField" promptText="e.g. SN-12345" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        
        <Label text="Device Type:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="deviceTypeBox" promptText="Select Category" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        
        <Label text="Device Purpose:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <ComboBox fx:id="purposeBox" promptText="Select Purpose" prefWidth="250.0" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
        
        <Label text="Remarks / Notes:" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <TextField fx:id="remarksField" promptText="Optional notes" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
    </GridPane>
    
    <Button text="Register Device" onAction="#handleRegister" prefWidth="180.0" style="-fx-font-weight: bold;"/>
</VBox>
