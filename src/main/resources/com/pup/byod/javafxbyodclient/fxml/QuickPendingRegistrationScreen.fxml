<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.QuickPendingRegistrationScreenController"
            stylesheets="@../css/admin_dashboard_styles.css"
            vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
            
    <content>
        <VBox spacing="15.0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="5.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
            
            <!-- Hero Header Banner -->
            <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
                <Label text="Quick Device Registration" styleClass="welcome-title"/>
                <Label text="Register external or guest devices on-the-fly directly to the pending database." styleClass="welcome-subtitle"/>
            </VBox>
            
            <!-- Registration Form Card -->
            <VBox spacing="15.0" maxWidth="550.0" alignment="TOP_LEFT"
                  style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                
                <Label text="REGISTRATION DETAILS" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #829AB1; -fx-text-transform: uppercase; -fx-padding: 0 0 5 0;"/>
                
                <VBox spacing="5.0">
                    <Label text="Student ID Number:" styleClass="form-label"/>
                    <TextField fx:id="studentIdField" promptText="e.g. 2021-10023" styleClass="modern-textfield" prefHeight="38.0"/>
                </VBox>
                
                <VBox spacing="5.0">
                    <Label text="Device Name:" styleClass="form-label"/>
                    <TextField fx:id="deviceNameField" promptText="e.g. Laptop" styleClass="modern-textfield" prefHeight="38.0"/>
                </VBox>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Brand:" styleClass="form-label"/>
                        <TextField fx:id="brandField" promptText="e.g. Asus" styleClass="modern-textfield" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Model:" styleClass="form-label"/>
                        <TextField fx:id="modelField" promptText="e.g. Zenbook" styleClass="modern-textfield" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                
                <VBox spacing="5.0">
                    <Label text="Serial Number:" styleClass="form-label"/>
                    <TextField fx:id="serialNumberField" promptText="e.g. SN-12345" styleClass="modern-textfield" prefHeight="38.0"/>
                </VBox>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Device Type:" styleClass="form-label"/>
                        <ComboBox fx:id="deviceTypeBox" promptText="Select Category" maxWidth="Infinity" styleClass="modern-combo-box" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Device Purpose:" styleClass="form-label"/>
                        <ComboBox fx:id="purposeBox" promptText="Select Purpose" maxWidth="Infinity" styleClass="modern-combo-box" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                
                <VBox spacing="5.0">
                    <Label text="Remarks / Notes:" styleClass="form-label"/>
                    <TextField fx:id="remarksField" promptText="Optional notes or context..." styleClass="modern-textfield" prefHeight="38.0"/>
                </VBox>
                
                <Separator style="-fx-padding: 10px 0 0 0;"/>
                
                <Button text="Register Device" onAction="#handleRegister" maxWidth="Infinity" prefHeight="40.0" styleClass="action-btn, action-btn-success"/>
            </VBox>
        </VBox>
    </content>
</ScrollPane>
