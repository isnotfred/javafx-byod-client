<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ResetPasswordScreenController"
      spacing="15.0" alignment="CENTER" prefWidth="450.0" prefHeight="280.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Reset Password" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="Please input the reset token from your email and enter your new password." wrapText="true" alignment="CENTER"/>

    <GridPane hgap="10.0" vgap="10.0" alignment="CENTER">
        <columnConstraints>
            <ColumnConstraints halignment="RIGHT" minWidth="130.0"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="220.0"/>
        </columnConstraints>
        
        <Label text="Security Token:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="tokenField" promptText="Paste reset token here" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="New Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <PasswordField fx:id="passwordField" promptText="Min 8 characters" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Confirm Password:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox spacing="15.0" alignment="CENTER">
        <Button text="Reset Password" onAction="#handleResetSubmit" style="-fx-font-weight: bold;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>
</VBox>
