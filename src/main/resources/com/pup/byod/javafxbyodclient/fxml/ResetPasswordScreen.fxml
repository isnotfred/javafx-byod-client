<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<VBox stylesheets="@../css/login.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.ResetPasswordScreenController"
      alignment="CENTER" spacing="15.0" style="-fx-background-color: transparent;">

    <VBox spacing="18.0" styleClass="login-card" maxWidth="380.0" prefWidth="340.0">
        <padding>
            <Insets top="28.0" right="24.0" bottom="28.0" left="24.0"/>
        </padding>

        <!-- Header -->
        <VBox alignment="CENTER" spacing="5.0">
            <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zM9 6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9V6zm9 14H6V10h12v10zm-6-3c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2z" style="-fx-fill: #F59E0B; -fx-scale-x: 1.3; -fx-scale-y: 1.3;">
                <VBox.margin>
                    <Insets bottom="6.0"/>
                </VBox.margin>
            </SVGPath>
            <Label text="Reset Password" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
            <Label text="Please input the reset token from your email and enter your new password." style="-fx-font-size: 11px; -fx-text-fill: #64748B;" wrapText="true" textAlignment="CENTER"/>
        </VBox>

        <!-- Token Field -->
        <VBox spacing="6.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <SVGPath content="M12.65 11.3c.3-.3.45-.7.45-1.1 0-1.7-1.3-3-3-3s-3 1.3-3 3 1.3 3 3 3c.4 0 .8-.15 1.1-.45L14.3 15H16v2h2v2h2.7l1.3-1.3-3.7-3.7 1.3-1.3-1.3-1.3-1.4zM10.1 11.2c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1z" styleClass="svg-icon-black"/>
                <Label text="Security Token" styleClass="login-label"/>
            </HBox>
            <TextField fx:id="tokenField" promptText="Paste reset token here" styleClass="login-textfield"/>
        </VBox>

        <!-- New Password Field -->
        <VBox spacing="6.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2z" styleClass="svg-icon-black"/>
                <Label text="New Password" styleClass="login-label"/>
            </HBox>
            <PasswordField fx:id="passwordField" promptText="Min 8 characters" styleClass="login-textfield"/>
        </VBox>

        <!-- Confirm Password Field -->
        <VBox spacing="6.0">
            <HBox alignment="CENTER_LEFT" spacing="8.0">
                <SVGPath content="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2z" styleClass="svg-icon-black"/>
                <Label text="Confirm Password" styleClass="login-label"/>
            </HBox>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="login-textfield"/>
        </VBox>

        <!-- Actions -->
        <VBox spacing="10.0">
            <Button text="Reset Password" onAction="#handleResetSubmit" maxWidth="Infinity" styleClass="login-btn"/>
            <Button text="Cancel" onAction="#handleCancel" maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #64748B; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </VBox>
    </VBox>
</VBox>
