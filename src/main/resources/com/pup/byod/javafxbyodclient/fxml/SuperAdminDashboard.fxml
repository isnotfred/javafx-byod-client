<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.SuperAdminDashboardController"
            prefWidth="1000.0" prefHeight="700.0">
            
    <fx:define>
        <ToggleGroup fx:id="sidebarGroup"/>
    </fx:define>
            
    <!-- Left Sidebar -->
    <left>
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="sidebar-scrollpane" style="-fx-background-color: #102A43; -fx-background: #102A43; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 0;">
            <VBox styleClass="sidebar-container" spacing="10.0" minHeight="-Infinity">
            
            <HBox styleClass="sidebar-logo-container" spacing="12.0" alignment="CENTER_LEFT">
                <ImageView fitHeight="32.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/BYOD_Logo.png"/>
                    </image>
                </ImageView>
                <VBox spacing="3.0" alignment="CENTER_LEFT">
                    <Label text="BYOD MANAGEMENT" styleClass="sidebar-title-text" style="-fx-font-size: 13px;"/>
                    <Label fx:id="roleBadge" styleClass="role-badge" text="ROLE"/>
                </VBox>
            </HBox>
            
            <Separator style="-fx-opacity: 0.15;"/>
            
            <!-- Sidebar Buttons with Icons -->
            <ToggleButton text="Dashboard" onAction="#showSummaryDashboard" toggleGroup="$sidebarGroup" selected="true" prefWidth="220.0" styleClass="sidebar-btn">
                <graphic>
                    <StackPane styleClass="sidebar-icon-container">
                        <SVGPath content="M2 2h8v8H2V2zm10 0h8v8h-8V2zM2 12h8v8H2v-8zm10 0h8v8h-8v-8z" styleClass="sidebar-icon"/>
                    </StackPane>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Operator Management" onAction="#showUserManagement" toggleGroup="$sidebarGroup" prefWidth="220.0" styleClass="sidebar-btn">
                <graphic>
                    <StackPane styleClass="sidebar-icon-container">
                        <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5z" styleClass="sidebar-icon"/>
                    </StackPane>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="System Configuration" onAction="#showSystemConfiguration" toggleGroup="$sidebarGroup" prefWidth="220.0" styleClass="sidebar-btn">
                <graphic>
                    <StackPane styleClass="sidebar-icon-container">
                        <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" styleClass="sidebar-icon"/>
                    </StackPane>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="System Audit Logs" onAction="#showSystemAuditLogs" toggleGroup="$sidebarGroup" prefWidth="220.0" styleClass="sidebar-btn">
                <graphic>
                    <StackPane styleClass="sidebar-icon-container">
                        <SVGPath content="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" styleClass="sidebar-icon"/>
                    </StackPane>
                </graphic>
            </ToggleButton>
            
            <ToggleButton text="Profile Management" onAction="#showProfile" toggleGroup="$sidebarGroup" prefWidth="220.0" styleClass="sidebar-btn">
                <graphic>
                    <StackPane styleClass="sidebar-icon-container">
                        <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="sidebar-icon"/>
                    </StackPane>
                </graphic>
            </ToggleButton>
            
            <Region VBox.vgrow="ALWAYS"/>
            <Separator style="-fx-opacity: 0.15;"/>
            <Button text="Logout" onAction="#handleLogout" prefWidth="220.0" styleClass="sidebar-btn">
                <graphic>
                    <SVGPath content="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" styleClass="sidebar-icon"/>
                </graphic>
            </Button>
            </VBox>
        </ScrollPane>
    </left>
    
    <!-- Right Content Area -->
    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0"/>
            </padding>
            <Label text="Please select an option from the sidebar."/>
        </StackPane>
    </center>
    
</BorderPane>
