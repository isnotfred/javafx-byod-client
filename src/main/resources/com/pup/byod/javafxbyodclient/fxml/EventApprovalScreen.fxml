<?xml version="1.0" encoding="UTF-8"?>
 
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
 
<StackPane stylesheets="@../css/admin_dashboard_styles.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pup.byod.javafxbyodclient.controller.EventApprovalScreenController"
           HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
      
    <!-- Base Layer: Main View -->
    <VBox spacing="15.0">
        <padding>
            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
        </padding>
        
        <!-- Hero Header Banner -->
        <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="Event Request Approvals" styleClass="welcome-title"/>
            <Label text="Review, approve, reject, or return event device clearance requests submitted by guards or organizers." styleClass="welcome-subtitle"/>
        </VBox>
        
        <!-- Request Log Registry Card -->
        <VBox spacing="12.0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search Student ID or Event..." HBox.hgrow="ALWAYS" styleClass="modern-textfield" prefHeight="38.0" maxWidth="300.0"/>
                <ComboBox fx:id="statusFilterBox" promptText="Filter Status" prefWidth="150.0" styleClass="modern-combo-box" prefHeight="38.0"/>
                <Button text="Search" onAction="#handleSearch" styleClass="action-btn, action-btn-primary" prefHeight="38.0"/>
                <Button text="Refresh" onAction="#loadEventRequests" styleClass="action-btn, action-btn-secondary" prefHeight="38.0"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="viewDetailsBtn" text="View Details" onAction="#openDetailsOverlay" disable="true" styleClass="action-btn, action-btn-warning" prefHeight="38.0"/>
            </HBox>
            
            <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="300.0">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colEventId" text="Req ID" prefWidth="60.0"/>
                    <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="110.0"/>
                    <TableColumn fx:id="colEventName" text="Event Name" prefWidth="130.0"/>
                    <TableColumn fx:id="colEventStatus" text="Status" prefWidth="90.0"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
      
    <!-- Overlay Layer: Request Details and Decisions -->
    <StackPane fx:id="detailsOverlay" visible="false" style="-fx-background-color: rgba(16, 42, 67, 0.45);" alignment="CENTER">
        <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
        </padding>
        
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" maxHeight="620.0" maxWidth="700.0" 
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            
            <!-- Detail Form Card -->
            <VBox spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.1), 15, 0, 0, 8);">
                
                <HBox alignment="CENTER_LEFT">
                    <Label text="Request Details &amp; Actions" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="✕" onAction="#closeDetailsOverlay" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 16px; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>
                
                <Separator/>
                 
                <!-- Event Details (View Only) -->
                <Label text="Event Clearances Details" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Student ID:" styleClass="form-label"/>
                        <TextField fx:id="formStudentIdField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Event Name:" styleClass="form-label"/>
                        <TextField fx:id="eventNameField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Responsible Person:" styleClass="form-label"/>
                        <TextField fx:id="responsiblePersonField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Organization / etc.:" styleClass="form-label"/>
                        <TextField fx:id="organizationField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Contact (Phone/Socials):" styleClass="form-label"/>
                        <TextField fx:id="contactField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Purpose:" styleClass="form-label"/>
                        <TextField fx:id="purposeField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Start Date:" styleClass="form-label"/>
                        <TextField fx:id="startDateField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="End Date:" styleClass="form-label"/>
                        <TextField fx:id="endDateField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                
                <HBox spacing="15.0">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Approval Doc Type:" styleClass="form-label"/>
                        <TextField fx:id="docTypeField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Doc Reference No:" styleClass="form-label"/>
                        <TextField fx:id="docRefField" editable="false" styleClass="modern-textfield, read-only-field" prefHeight="38.0"/>
                    </VBox>
                </HBox>
                 
                <Separator/>
                 
                <!-- Devices List -->
                <Label text="Associated Devices" styleClass="form-label" style="-fx-text-fill: #0284C7; -fx-font-size: 13px;"/>
                <TableView fx:id="itemsTable" prefHeight="130.0" minHeight="100.0" styleClass="modern-table">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colItemId" text="Item ID" prefWidth="60.0"/>
                        <TableColumn fx:id="colItemName" text="Device Name" prefWidth="120.0"/>
                        <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="120.0"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="110.0"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="80.0"/>
                    </columns>
                </TableView>
                 
                <Separator/>
                 
                <!-- Remarks Section -->
                <VBox spacing="5.0">
                    <Label text="Reviewer Remarks (Mandatory if Rejecting/Returning):" styleClass="form-label"/>
                    <TextArea fx:id="remarksArea" promptText="Enter comments/remarks for this request..." styleClass="modern-textarea" prefHeight="70.0"/>
                </VBox>
                 
                <!-- Decision Buttons -->
                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <Button fx:id="returnBtn" text="Return Request" onAction="#handleReturn" styleClass="action-btn, action-btn-secondary" prefHeight="38.0" prefWidth="150.0"/>
                    <Button fx:id="rejectBtn" text="Reject Request" onAction="#handleReject" styleClass="action-btn, action-btn-danger" prefHeight="38.0" prefWidth="150.0"/>
                    <Button fx:id="approveBtn" text="Approve Request" onAction="#handleApprove" styleClass="action-btn, action-btn-success" prefHeight="38.0" prefWidth="150.0"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </StackPane>
     
</StackPane>
