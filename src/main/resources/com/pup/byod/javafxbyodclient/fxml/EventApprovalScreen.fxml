<?xml version="1.0" encoding="UTF-8"?>
 
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
 
<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.EventApprovalScreenController"
      spacing="15.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
       
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>
     
    <!-- Left Section: Event Request List -->
    <VBox spacing="10.0" minWidth="380.0" prefWidth="430.0" HBox.hgrow="ALWAYS">
        <Label text="Event Request Approvals" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search Student ID or Event" HBox.hgrow="ALWAYS"/>
            <ComboBox fx:id="statusFilterBox" promptText="Filter Status" prefWidth="120.0"/>
            <Button text="Search" onAction="#handleSearch"/>
            <Button text="Refresh" onAction="#loadEventRequests"/>
        </HBox>
        <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colEventId" text="Req ID" prefWidth="60.0"/>
                <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="110.0"/>
                <TableColumn fx:id="colEventName" text="Event Name" prefWidth="130.0"/>
                <TableColumn fx:id="colEventStatus" text="Status" prefWidth="90.0"/>
            </columns>
        </TableView>
    </VBox>
     
    <Separator orientation="VERTICAL"/>
     
    <!-- Right Section: Selected Event Request Details and Decisions -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" HBox.hgrow="ALWAYS" minWidth="450.0" prefWidth="550.0" style="-fx-background-color: transparent; -fx-background: transparent;">
        <VBox spacing="15.0">
            <padding>
                <Insets right="10.0" left="5.0"/>
            </padding>
             
            <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #cbd5e1; -fx-border-width: 1; -fx-border-radius: 8; -fx-background-radius: 8;">
                <Label text="Request Details" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                <Separator/>
                 
                <!-- Event Details (View Only) -->
                <GridPane hgap="10.0" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="35.0"/>
                        <ColumnConstraints percentWidth="65.0"/>
                    </columnConstraints>
                     
                    <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="formStudentIdField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                     
                    <Label text="Responsible Person:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="responsiblePersonField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                     
                    <Label text="Contact (Phone/Socials):" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="contactField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                     
                    <Label text="Event Name:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="eventNameField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                     
                    <Label text="Organization / etc.:" GridPane.columnIndex="0" GridPane.rowIndex="4" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="organizationField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                     
                    <Label text="Purpose:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="purposeField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                     
                    <Label text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="6" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="startDateField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                     
                    <Label text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="7" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="endDateField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                     
                    <Label text="Approval Doc Type:" GridPane.columnIndex="0" GridPane.rowIndex="8" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="docTypeField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                     
                    <Label text="Doc Reference No:" GridPane.columnIndex="0" GridPane.rowIndex="9" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextField fx:id="docRefField" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="9"/>
                </GridPane>
                 
                <Separator/>
                 
                <!-- Devices List -->
                <Label text="Associated Devices" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;"/>
                <TableView fx:id="itemsTable" prefHeight="130.0" minHeight="100.0">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colItemId" text="Item ID" prefWidth="60.0"/>
                        <TableColumn fx:id="colItemName" text="Device Name" prefWidth="120.0"/>
                        <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="120.0"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="110.0"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="80.0"/>
                    </columns>
                </TableView>
                 
                <Separator/>
                 
                <!-- Remarks Section -->
                <VBox spacing="5.0">
                    <Label text="Reviewer Remarks (Mandatory if Rejecting/Returning):" style="-fx-font-weight: bold; -fx-text-fill: #475569;"/>
                    <TextArea fx:id="remarksArea" promptText="Enter comments/remarks for this request..." prefHeight="70.0"/>
                </VBox>
                 
                <!-- Decision Buttons -->
                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                    <Button fx:id="returnBtn" text="Return" onAction="#handleReturn" style="-fx-background-color: #e2e8f0; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 16px;"/>
                    <Button fx:id="rejectBtn" text="Reject" onAction="#handleReject" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 16px;"/>
                    <Button fx:id="approveBtn" text="Approve" onAction="#handleApprove" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8px 16px;"/>
                </HBox>
            </VBox>
        </VBox>
    </ScrollPane>
     
</HBox>
