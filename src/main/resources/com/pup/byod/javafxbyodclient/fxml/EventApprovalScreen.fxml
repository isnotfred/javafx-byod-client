<?xml version="1.0" encoding="UTF-8"?>
 
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
 
<StackPane stylesheets="@../css/event_approval.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.EventApprovalScreenController"
      styleClass="module-container">
       
    <padding>
        <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
    </padding>
     
    <!-- Base Layer: Event Request List -->
    <VBox spacing="15.0" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" styleClass="module-card">
        <Label text="Event Request Approvals" styleClass="module-header"/>
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search Student ID or Event" HBox.hgrow="ALWAYS" styleClass="modern-textfield"/>
            <ComboBox fx:id="statusFilterBox" promptText="Filter Status" prefWidth="120.0" styleClass="modern-combo-box"/>
            <Button text="Search" onAction="#handleSearch" styleClass="action-btn, action-btn-primary"/>
            <Button text="Refresh" onAction="#loadEventRequests" styleClass="action-btn, action-btn-secondary"/>
        </HBox>
        <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colEventId" text="Req ID" prefWidth="60.0"/>
                <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="110.0"/>
                <TableColumn fx:id="colEventName" text="Event Name" prefWidth="130.0"/>
                <TableColumn fx:id="colEventStatus" text="Status" prefWidth="90.0"/>
            </columns>
        </TableView>
        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <Button fx:id="viewDetailsBtn" text="View Request Details" onAction="#openDetailsOverlay" disable="true" styleClass="action-btn, action-btn-primary" prefHeight="35.0"/>
        </HBox>
    </VBox>
     
    <!-- Overlay Layer: Request Details and Decisions -->
    <StackPane fx:id="detailsOverlay" visible="false" style="-fx-background-color: rgba(16, 42, 67, 0.4);">
        <StackPane maxWidth="700.0" maxHeight="650.0" styleClass="module-card">
            
            <Button text="✕" onAction="#closeDetailsOverlay" StackPane.alignment="TOP_RIGHT" 
                    style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-text-fill: #94A3B8; -fx-cursor: hand; -fx-font-size: 16px;">
                <StackPane.margin>
                    <Insets top="-5.0" right="-5.0"/>
                </StackPane.margin>
            </Button>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                <VBox spacing="15.0">
                    <padding>
                        <Insets right="10.0" left="5.0" top="10.0" bottom="10.0"/>
                    </padding>
                     
                    <VBox spacing="15.0">
                        <Label text="Request Details" styleClass="module-subheader"/>
                        <Separator/>
                         
                        <!-- Event Details (View Only) -->
                        <GridPane hgap="10.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="35.0"/>
                                <ColumnConstraints percentWidth="65.0"/>
                            </columnConstraints>
                             
                            <Label text="Student ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                            <TextField fx:id="formStudentIdField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                             
                            <Label text="Responsible Person:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                            <TextField fx:id="responsiblePersonField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                             
                            <Label text="Contact (Phone/Socials):" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                            <TextField fx:id="contactField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                             
                            <Label text="Event Name:" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="form-label"/>
                            <TextField fx:id="eventNameField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                             
                            <Label text="Organization / etc.:" GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="form-label"/>
                            <TextField fx:id="organizationField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                             
                            <Label text="Purpose:" GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="form-label"/>
                            <TextField fx:id="purposeField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                             
                            <Label text="Start Date:" GridPane.columnIndex="0" GridPane.rowIndex="6" styleClass="form-label"/>
                            <TextField fx:id="startDateField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                             
                            <Label text="End Date:" GridPane.columnIndex="0" GridPane.rowIndex="7" styleClass="form-label"/>
                            <TextField fx:id="endDateField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="7"/>
                             
                            <Label text="Approval Doc Type:" GridPane.columnIndex="0" GridPane.rowIndex="8" styleClass="form-label"/>
                            <TextField fx:id="docTypeField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="8"/>
                             
                            <Label text="Doc Reference No:" GridPane.columnIndex="0" GridPane.rowIndex="9" styleClass="form-label"/>
                            <TextField fx:id="docRefField" editable="false" styleClass="modern-textfield, read-only-field" GridPane.columnIndex="1" GridPane.rowIndex="9"/>
                        </GridPane>
                         
                        <Separator/>
                         
                        <!-- Devices List -->
                        <Label text="Associated Devices" styleClass="form-label" style="-fx-text-fill: #0284C7;"/>
                        <TableView fx:id="itemsTable" prefHeight="130.0" minHeight="100.0" styleClass="modern-table">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colItemId" text="Item ID" prefWidth="60.0"/>
                                <TableColumn fx:id="colItemName" text="Device Name" prefWidth="120.0"/>
                                <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="120.0"/>
                                <TableColumn fx:id="colType" text="Type" prefWidth="110.0"/>
                                <TableColumn fx:id="colStatus" text="Status" prefWidth="80.0"/>
                            </columns>
                        </TableView>
                         
                        <Separator/>
                         
                        <!-- Remarks Section -->
                        <VBox spacing="5.0">
                            <Label text="Reviewer Remarks (Mandatory if Rejecting/Returning):" styleClass="form-label"/>
                            <TextArea fx:id="remarksArea" promptText="Enter comments/remarks for this request..." styleClass="modern-textarea" prefHeight="70.0"/>
                        </VBox>
                         
                        <!-- Decision Buttons -->
                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                            <Button fx:id="returnBtn" text="Return" onAction="#handleReturn" styleClass="action-btn, action-btn-secondary"/>
                            <Button fx:id="rejectBtn" text="Reject" onAction="#handleReject" styleClass="action-btn, action-btn-danger"/>
                            <Button fx:id="approveBtn" text="Approve" onAction="#handleApprove" styleClass="action-btn, action-btn-success"/>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </StackPane>
     
</StackPane>
