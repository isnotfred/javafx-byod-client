<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 0;"
            stylesheets="@../css/admin_dashboard_styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.ProfileScreenController"
            vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
            
    <content>
        <VBox spacing="20.0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            <padding>
                <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
            </padding>
            
            <!-- Hero Header Banner -->
            <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
                <Label text="Profile &amp; Credentials Management" styleClass="welcome-title"/>
                <Label text="View or update your account email credentials and system security settings." styleClass="welcome-subtitle"/>
            </VBox>
            
            <!-- SIDE BY SIDE CONTAINER -->
            <HBox spacing="20.0" alignment="TOP_CENTER" maxWidth="Infinity">
            
                <!-- Left Card: Profile Info -->
                <VBox spacing="20.0" HBox.hgrow="ALWAYS" alignment="TOP_LEFT"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                    
                    <Label text="Profile Information" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Separator/>
                    
                    <GridPane hgap="15.0" vgap="16.0">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120.0" maxWidth="120.0"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
                        </columnConstraints>
                        
                        <Label text="Username / Email:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <TextField fx:id="usernameField" promptText="Enter username" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="modern-textfield" prefHeight="38.0"/>
                        
                        <Label text="System Role:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <Label fx:id="roleLabel" text="-" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0284C7;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    
                        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <Label fx:id="fullNameLabel" text="-" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #102A43;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>
                    
                    <Region VBox.vgrow="ALWAYS"/>
                    <Separator/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Update Username" onAction="#handleUpdateUsername" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="40.0" styleClass="action-btn, action-btn-primary"/>
                    </HBox>
                </VBox>
                
                <!-- Right Card: Security -->
                <VBox spacing="20.0" HBox.hgrow="ALWAYS" alignment="TOP_LEFT"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 24px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                    
                    <Label text="Security &amp; Password" styleClass="module-subheader" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Separator/>
                    
                    <GridPane hgap="15.0" vgap="16.0">
                        <columnConstraints>
                            <ColumnConstraints halignment="RIGHT" minWidth="120.0" maxWidth="120.0"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
                        </columnConstraints>
                        
                        <Label text="Current Password:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                        <StackPane alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                            <TextField fx:id="currentPasswordVisibleField" promptText="Enter current password" styleClass="modern-textfield" prefHeight="38.0" maxWidth="Infinity" visible="false" managed="false"/>
                            <PasswordField fx:id="currentPasswordField" promptText="Enter current password" styleClass="modern-password-field" prefHeight="38.0" maxWidth="Infinity"/>
                            <Button onAction="#toggleCurrentPassword" style="-fx-background-color: transparent; -fx-cursor: hand;" prefHeight="38.0">
                                <graphic>
                                    <SVGPath fx:id="currentToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" style="-fx-fill: #475569;"/>
                                </graphic>
                            </Button>
                        </StackPane>
                        
                        <Label text="New Password:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                        <StackPane alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                            <TextField fx:id="newPasswordVisibleField" promptText="Enter new password" styleClass="modern-textfield" prefHeight="38.0" maxWidth="Infinity" visible="false" managed="false"/>
                            <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="modern-password-field" prefHeight="38.0" maxWidth="Infinity"/>
                            <Button onAction="#toggleNewPassword" style="-fx-background-color: transparent; -fx-cursor: hand;" prefHeight="38.0">
                                <graphic>
                                    <SVGPath fx:id="newToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" style="-fx-fill: #475569;"/>
                                </graphic>
                            </Button>
                        </StackPane>
                        
                        <Label text="Confirm Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                        <StackPane alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.hgrow="ALWAYS">
                            <TextField fx:id="confirmPasswordVisibleField" promptText="Confirm new password" styleClass="modern-textfield" prefHeight="38.0" maxWidth="Infinity" visible="false" managed="false"/>
                            <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="modern-password-field" prefHeight="38.0" maxWidth="Infinity"/>
                            <Button onAction="#toggleConfirmPassword" style="-fx-background-color: transparent; -fx-cursor: hand;" prefHeight="38.0">
                                <graphic>
                                    <SVGPath fx:id="confirmToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" style="-fx-fill: #475569;"/>
                                </graphic>
                            </Button>
                        </StackPane>
                    </GridPane>
                    
                    <Separator/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Update Password" onAction="#handleUpdatePassword" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefHeight="40.0" styleClass="action-btn, action-btn-success"/>
                    </HBox>
                </VBox>
                
            </HBox>
        </VBox>
    </content>
</ScrollPane>
