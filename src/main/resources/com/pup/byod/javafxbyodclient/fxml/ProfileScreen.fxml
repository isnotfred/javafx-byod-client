<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" stylesheets="@../css/profile.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pup.byod.javafxbyodclient.controller.ProfileScreenController">
    <VBox spacing="20.0" alignment="TOP_CENTER" styleClass="module-container" VBox.vgrow="ALWAYS">
        
        <Label text="Profile &amp; Credentials Management" styleClass="module-header"/>
        
        <!-- SIDE BY SIDE CONTAINER -->
        <HBox spacing="20.0" alignment="TOP_CENTER">
        
            <!-- Left Card: Profile Info -->
            <VBox spacing="15.0" maxWidth="500.0" HBox.hgrow="ALWAYS" alignment="TOP_LEFT" styleClass="module-card">
                <Label text="Profile Information" styleClass="module-subheader"/>
                
                <GridPane hgap="15.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
                    </columnConstraints>
                    
                    <Label text="Username / Email:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <TextField fx:id="usernameField" promptText="Enter username" GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="modern-textfield"/>
                    
                    <Label text="System Role:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <Label fx:id="roleLabel" text="-" style="-fx-font-weight: bold; -fx-text-fill: #102A43;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                    <Label fx:id="fullNameLabel" text="-" style="-fx-font-weight: bold; -fx-text-fill: #102A43;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                
                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 5px 0 0 0;">
                    <Button text="Update Username" onAction="#handleUpdateUsername" prefWidth="180.0" styleClass="action-btn, action-btn-primary"/>
                </HBox>
            </VBox>
            
            <!-- Right Card: Security -->
            <VBox spacing="15.0" maxWidth="500.0" HBox.hgrow="ALWAYS" alignment="TOP_LEFT" styleClass="module-card">
                <Label text="Security &amp; Password" styleClass="module-subheader"/>
                
                <GridPane hgap="15.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints halignment="RIGHT" minWidth="120.0"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200.0"/>
                    </columnConstraints>
                    
                    <Label text="Current Password:" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="form-label"/>
                    <StackPane alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS">
                        <TextField fx:id="currentPasswordVisibleField" promptText="Enter current password" styleClass="modern-textfield" maxWidth="Infinity" visible="false" managed="false"/>
                        <PasswordField fx:id="currentPasswordField" promptText="Enter current password" styleClass="modern-password-field" maxWidth="Infinity"/>
                        <Button onAction="#toggleCurrentPassword" style="-fx-background-color: transparent; -fx-cursor: hand;">
                            <graphic>
                                <SVGPath fx:id="currentToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" style="-fx-fill: #1E293B;"/>
                            </graphic>
                        </Button>
                    </StackPane>
                    
                    <Label text="New Password:" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="form-label"/>
                    <StackPane alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS">
                        <TextField fx:id="newPasswordVisibleField" promptText="Enter new password" styleClass="modern-textfield" maxWidth="Infinity" visible="false" managed="false"/>
                        <PasswordField fx:id="newPasswordField" promptText="Enter new password" styleClass="modern-password-field" maxWidth="Infinity"/>
                        <Button onAction="#toggleNewPassword" style="-fx-background-color: transparent; -fx-cursor: hand;">
                            <graphic>
                                <SVGPath fx:id="newToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" style="-fx-fill: #1E293B;"/>
                            </graphic>
                        </Button>
                    </StackPane>
                    
                    <Label text="Confirm Password:" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="form-label"/>
                    <StackPane alignment="CENTER_RIGHT" GridPane.columnIndex="1" GridPane.rowIndex="2" GridPane.hgrow="ALWAYS">
                        <TextField fx:id="confirmPasswordVisibleField" promptText="Confirm new password" styleClass="modern-textfield" maxWidth="Infinity" visible="false" managed="false"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" styleClass="modern-password-field" maxWidth="Infinity"/>
                        <Button onAction="#toggleConfirmPassword" style="-fx-background-color: transparent; -fx-cursor: hand;">
                            <graphic>
                                <SVGPath fx:id="confirmToggleIcon" content="M12 7c2.76 0 5 2.24 5 5 0 .65-.13 1.26-.36 1.83l2.92 2.92c1.51-1.26 2.7-2.89 3.43-4.75-1.73-4.39-6-7.5-11-7.5-1.4 0-2.74.25-3.98.7l2.16 2.16C10.74 7.13 11.35 7 12 7zM2 4.27l2.28 2.28.46.46C3.08 8.3 1.78 10.02 1 12c1.73 4.39 6 7.5 11 7.5 1.55 0 3.03-.3 4.38-.84l.42.42L19.73 22 21 20.73 3.27 3 2 4.27zM7.53 9.8l1.55 1.55c-.05.21-.08.43-.08.65 0 1.66 1.34 3 3 3 .22 0 .44-.03.65-.08l1.55 1.55c-.67.33-1.41.53-2.2.53-2.76 0-5-2.24-5-5 0-.79.2-1.53.53-2.2zm4.31-.78l3.15 3.15.02-.16c0-1.66-1.34-3-3-3l-.17.01z" style="-fx-fill: #1E293B;"/>
                            </graphic>
                        </Button>
                    </StackPane>
                </GridPane>
                
                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 5px 0 0 0;">
                    <Button text="Update Password" onAction="#handleUpdatePassword" prefWidth="180.0" styleClass="action-btn, action-btn-success"/>
                </HBox>
            </VBox>
            
        </HBox>
    </VBox>
</ScrollPane>
