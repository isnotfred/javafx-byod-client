<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.IngressEgressMonitoringScreenController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            
    <VBox spacing="15.0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS"
          stylesheets="@../css/admin_dashboard_styles.css">
          
        <padding>
            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
        </padding>
    
    <!-- Hero Header Banner -->
    <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label text="Security Gate Scanning &amp; Monitoring" styleClass="welcome-title"/>
        <Label text="Log and monitor student device check-ins and check-outs at the campus gates." styleClass="welcome-subtitle"/>
    </VBox>
    
    <!-- Main Content Split Layout -->
    <HBox spacing="15.0" VBox.vgrow="ALWAYS" alignment="TOP_CENTER" maxWidth="Infinity">
        
        <!-- Left Side: Search & Actions Card Stack (Width: 320px) -->
        <VBox spacing="15.0" prefWidth="320.0" minWidth="320.0" maxWidth="320.0" alignment="TOP_CENTER">
            
            <!-- Search Student Card -->
            <VBox spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                <Label text="LOOKUP STUDENT" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #829AB1; -fx-text-transform: uppercase;"/>
                <VBox spacing="6.0">
                    <Label text="Student ID Number:" styleClass="form-label"/>
                    <HBox spacing="8.0" alignment="CENTER_LEFT">
                        <TextField fx:id="studentIdField" promptText="e.g. 2021-00001" HBox.hgrow="ALWAYS" prefHeight="38.0" styleClass="modern-textfield"/>
                        <Button text="Lookup" onAction="#handleStudentSearch" prefHeight="38.0" styleClass="action-btn, action-btn-primary"/>
                    </HBox>
                </VBox>
            </VBox>
            
            <!-- Student Profile Details Card -->
            <VBox fx:id="studentCard" spacing="12.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px;">
                <Label text="STUDENT PROFILE" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0284C7; -fx-text-transform: uppercase;"/>
                <VBox spacing="4.0">
                    <Label fx:id="studentNameLabel" text="Student: No Selection" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Label fx:id="studentCourseLabel" text="Course &amp; Year: -" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 13px; -fx-text-fill: #475569;"/>
                </VBox>
                <Separator style="-fx-opacity: 0.5;"/>
                <Label fx:id="statusLabel" text="STATUS: READY TO LOOKUP" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
            </VBox>
            
            <!-- Gate Logging Actions Card -->
            <VBox spacing="12.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                <Label text="GATE ACTIONS" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #829AB1; -fx-text-transform: uppercase;"/>
                <VBox spacing="6.0">
                    <Label text="Remarks / Notes:" styleClass="form-label"/>
                    <TextArea fx:id="notesArea" promptText="Optional entry/exit notes or override remarks..." prefHeight="70.0" minHeight="60.0" styleClass="modern-textarea" wrapText="true"/>
                </VBox>
                
                <VBox spacing="10.0" alignment="CENTER" style="-fx-padding: 8px 0 0 0;">
                    <Button text="Log Entry (Check-In)" onAction="#handleEntry" maxWidth="Infinity" prefHeight="40.0" styleClass="action-btn, action-btn-success"/>
                    <Button text="Log Exit (Check-Out)" onAction="#handleExit" maxWidth="Infinity" prefHeight="40.0" styleClass="action-btn, action-btn-primary"/>
                </VBox>
            </VBox>
            
        </VBox>
        
        <!-- Right Side: Device Selection & History Tables -->
        <VBox spacing="15.0" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
            
            <!-- Registered Devices Table Card -->
            <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Registered Devices" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Tick devices brought inside" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 12px; -fx-text-fill: #64748B;"/>
                </HBox>
                <TableView fx:id="deviceTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="150.0">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colSelect" text="Select" prefWidth="55.0"/>
                        <TableColumn fx:id="colDeviceName" text="Device Name" prefWidth="150.0"/>
                        <TableColumn fx:id="colBrand" text="Brand" prefWidth="110.0"/>
                        <TableColumn fx:id="colModel" text="Model" prefWidth="110.0"/>
                        <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="160.0"/>
                        <TableColumn fx:id="colStatus" text="Campus Status" prefWidth="110.0"/>
                    </columns>
                </TableView>
            </VBox>
            
            <!-- Scan Log History Card -->
            <VBox spacing="10.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <Label text="Scan Log History" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Export Logs" onAction="#handleExportLogs" styleClass="action-btn" prefHeight="30.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-text-fill: #475569; -fx-font-size: 12px;"/>
                </HBox>
                <TableView fx:id="logsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="150.0">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colLogId" text="Log ID" prefWidth="65.0"/>
                        <TableColumn fx:id="colLogType" text="Event Type" prefWidth="110.0"/>
                        <TableColumn fx:id="colLogTime" text="Event Timestamp" prefWidth="190.0"/>
                        <TableColumn fx:id="colLogHandler" text="Handled By ID" prefWidth="100.0"/>
                        <TableColumn fx:id="colLogNotes" text="Notes" prefWidth="220.0"/>
                    </columns>
                </TableView>
            </VBox>
            
        </VBox>
        
    </HBox>
    
</VBox>
</ScrollPane>
