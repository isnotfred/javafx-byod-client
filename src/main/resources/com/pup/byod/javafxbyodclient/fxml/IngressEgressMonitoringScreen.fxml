<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.IngressEgressMonitoringScreenController"
      spacing="15.0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
      
    <padding>
        <Insets top="10.0" right="15.0" bottom="15.0" left="15.0"/>
    </padding>
    
    <Label text="Security Gate Scanning &amp; Monitoring" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
    
    <!-- Student ID Search Section -->
    <HBox spacing="10.0" alignment="CENTER" maxWidth="600.0">
        <Label text="Student ID:" style="-fx-font-weight: bold; -fx-text-fill: #475569; -fx-font-size: 14px;"/>
        <TextField fx:id="studentIdField" promptText="Enter Student ID (e.g. 2021-00001)" HBox.hgrow="ALWAYS" prefHeight="35.0"/>
        <Button text="Lookup Student" onAction="#handleStudentSearch" prefHeight="35.0" style="-fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
    
    <!-- Student Information Card (Visible when student found) -->
    <VBox fx:id="studentCard" spacing="10.0" alignment="CENTER_LEFT" maxWidth="600.0" 
          style="-fx-border-color: #cbd5e1; -fx-border-width: 1px; -fx-border-radius: 6px; -fx-background-color: #f8fafc; -fx-padding: 12.0;">
        <Label fx:id="studentNameLabel" text="Student: No Selection" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
        <Label fx:id="studentCourseLabel" text="Course &amp; Year: -" style="-fx-font-size: 13px; -fx-text-fill: #475569;"/>
        <Label fx:id="statusLabel" text="STATUS: READY TO LOOKUP" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #64748b;"/>
    </VBox>
    
    <!-- Registered Devices Table (With Checkboxes) -->
    <VBox spacing="5.0" maxWidth="800.0" VBox.vgrow="ALWAYS">
        <Label text="Registered Devices (Tick devices brought inside)" style="-fx-font-weight: bold; -fx-text-fill: #334155;"/>
        <TableView fx:id="deviceTable" prefHeight="150.0" minHeight="120.0" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colSelect" text="Select" prefWidth="50.0"/>
                <TableColumn fx:id="colDeviceName" text="Device Name" prefWidth="120.0"/>
                <TableColumn fx:id="colBrand" text="Brand" prefWidth="90.0"/>
                <TableColumn fx:id="colModel" text="Model" prefWidth="90.0"/>
                <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="150.0"/>
                <TableColumn fx:id="colStatus" text="Campus Status" prefWidth="100.0"/>
            </columns>
        </TableView>
    </VBox>
    
    <!-- Scan Notes & Controls -->
    <VBox spacing="10.0" maxWidth="600.0" alignment="CENTER">
        <TextArea fx:id="notesArea" promptText="Optional entry/exit notes or override remarks" prefHeight="50.0" minHeight="40.0"/>
        
        <HBox spacing="20.0" alignment="CENTER">
            <Button text="Log Entry (Check-In)" onAction="#handleEntry" prefWidth="200.0" prefHeight="35.0" style="-fx-font-weight: bold; -fx-background-color: #22c55e; -fx-text-fill: white; -fx-cursor: hand;"/>
            <Button text="Log Exit (Check-Out)" onAction="#handleExit" prefWidth="200.0" prefHeight="35.0" style="-fx-font-weight: bold; -fx-background-color: #3b82f6; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
    </VBox>
    
    <Separator maxWidth="800.0"/>
    
    <!-- Ingress/Egress Log History for this Student -->
    <VBox spacing="5.0" maxWidth="800.0" prefHeight="180.0" minHeight="140.0">
        <Label text="Scan Log History (Selected Student)" style="-fx-font-weight: bold; -fx-text-fill: #334155;"/>
        <TableView fx:id="logsTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colLogId" text="Log ID" prefWidth="60.0"/>
                <TableColumn fx:id="colLogType" text="Event Type" prefWidth="100.0"/>
                <TableColumn fx:id="colLogTime" text="Event Timestamp" prefWidth="180.0"/>
                <TableColumn fx:id="colLogHandler" text="Handled By ID" prefWidth="100.0"/>
                <TableColumn fx:id="colLogNotes" text="Notes" prefWidth="200.0"/>
            </columns>
        </TableView>
    </VBox>
    
</VBox>
