<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pup.byod.javafxbyodclient.controller.IngressEgressMonitoringScreenController"
           stylesheets="@../css/admin_dashboard_styles.css"
           HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
       
    <!-- Main Content Area -->
    <VBox spacing="15.0" VBox.vgrow="ALWAYS" maxWidth="Infinity">
        <padding>
            <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
        </padding>
        
        <!-- Hero Header Banner -->
        <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="Gate Ingress/Egress Monitoring" styleClass="welcome-title"/>
            <Label text="Monitor campus access points, verify student identities, and manage device entry/exit event logs." styleClass="welcome-subtitle"/>
        </VBox>
        
        <!-- Consolidated Main Content Card -->
        <VBox spacing="15.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);" maxWidth="Infinity">
            
            <!-- 1. Search Student Section -->
            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <Label text="Student ID:" styleClass="form-label" style="-fx-min-width: 80px; -fx-font-weight: bold;"/>
                <TextField fx:id="studentIdField" promptText="e.g. 2021-00001" HBox.hgrow="ALWAYS" prefHeight="38.0" styleClass="modern-textfield"/>
                <Button text="Search" onAction="#handleStudentSearch" prefHeight="38.0" prefWidth="100.0" styleClass="action-btn, action-btn-primary"/>
            </HBox>
            
            <!-- 2. Student Profile Details Sub-Card -->
            <VBox fx:id="studentCard" spacing="10.0" alignment="CENTER_LEFT"
                  style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px;" maxWidth="Infinity">
                <Label text="STUDENT PROFILE DETAILS" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #0284C7; -fx-text-transform: uppercase;"/>
                <GridPane hgap="20.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="130.0" prefWidth="150.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="20.0" />
                        <RowConstraints minHeight="20.0" />
                        <RowConstraints minHeight="20.0" />
                    </rowConstraints>
                    
                    <Label text="Student Number (SN):" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px; -fx-text-fill: #64748B;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="studentSnLabel" text="-" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Name:" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px; -fx-text-fill: #64748B;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="studentNameLabel" text="No Selection" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #102A43;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    
                    <Label text="Course, Year &amp; Level:" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px; -fx-text-fill: #64748B;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="studentCourseLabel" text="-" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px; -fx-text-fill: #1E293B;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                </GridPane>
                <Separator style="-fx-opacity: 0.3;"/>
                <Label fx:id="statusLabel" text="STATUS: READY TO SEARCH" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
            </VBox>

            <!-- 3. Access Request List Section -->
            <VBox spacing="8.0" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                <Label text="Access Request List" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="150.0">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colReqName" text="Event Name" prefWidth="380.0" reorderable="false"/>
                        <TableColumn fx:id="colReqActionType" text="Expected Entry/Exit" prefWidth="180.0" reorderable="false"/>
                        <TableColumn fx:id="colReqView" text="View Button" prefWidth="130.0" reorderable="false"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </VBox>
    
    <!-- Semi-transparent Black Overlay for Modal Popup background -->
    <Region fx:id="overlay" style="-fx-background-color: rgba(0, 0, 0, 0.55);" visible="false" managed="false"/>
    
</StackPane>
