<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pup.byod.javafxbyodclient.controller.IngressEgressMonitoringScreenController"
           stylesheets="@../css/admin_dashboard_styles.css"
           style="-fx-background-color: #F8FAFC;">
       
    <!-- Main Content Area -->
    <VBox spacing="12.0" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="12.0" right="15.0" bottom="12.0" left="15.0"/>
        </padding>
        
        <!-- 1. Search Student Card -->
        <VBox spacing="8.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.03), 5, 0, 0, 1);" maxWidth="Infinity">
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Student ID:" styleClass="form-label" style="-fx-min-width: 80px; -fx-font-weight: bold;"/>
                <TextField fx:id="studentIdField" promptText="e.g. 2021-00001" HBox.hgrow="ALWAYS" prefHeight="34.0" styleClass="modern-textfield"/>
                <Button text="Search" onAction="#handleStudentSearch" prefHeight="34.0" prefWidth="100.0" styleClass="action-btn, action-btn-primary"/>
            </HBox>
        </VBox>
        
        <!-- 2. Student Profile Details Card -->
        <VBox fx:id="studentCard" spacing="10.0" alignment="CENTER_LEFT"
              style="-fx-background-color: #F8FAFC; -fx-border-color: #CBD5E1; -fx-border-width: 1px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 12px;" maxWidth="Infinity">
            <Label text="STUDENT PROFILE DETAILS" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 10px; -fx-font-weight: bold; -fx-text-fill: #0284C7; -fx-text-transform: uppercase;"/>
            <GridPane hgap="20.0" vgap="4.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="130.0" prefWidth="150.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="20.0" />
                    <RowConstraints minHeight="20.0" />
                    <RowConstraints minHeight="20.0" />
                </rowConstraints>
                
                <Label text="Student Number (SN):" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-text-fill: #64748B;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="studentSnLabel" text="-" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #1E293B;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                
                <Label text="Name:" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-text-fill: #64748B;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="studentNameLabel" text="No Selection" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', sans-serif; -fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #102A43;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                
                <Label text="Course, Year &amp; Level:" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-text-fill: #64748B;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="studentCourseLabel" text="-" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 12px; -fx-text-fill: #1E293B;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>
            <Separator style="-fx-opacity: 0.3;"/>
            <Label fx:id="statusLabel" text="STATUS: READY TO SEARCH" style="-fx-font-family: 'Inter', sans-serif; -fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #64748B;"/>
        </VBox>

        <!-- 3. Access Request List Card -->
        <VBox spacing="8.0" VBox.vgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 10px; -fx-background-radius: 10px; -fx-padding: 12px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.03), 5, 0, 0, 1);" maxWidth="Infinity">
            <Label text="Active Access Clearances" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
            <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="150.0">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colReqName" text="Event Name" prefWidth="380.0"/>
                    <TableColumn fx:id="colReqVenue" text="Venue" prefWidth="180.0"/>
                    <TableColumn fx:id="colReqActionType" text="Expected Entry/Exit" prefWidth="180.0"/>
                    <TableColumn fx:id="colReqView" text="View Button" prefWidth="130.0"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>
    
    <!-- Semi-transparent Black Overlay for Modal Popup background -->
    <Region fx:id="overlay" style="-fx-background-color: rgba(0, 0, 0, 0.55);" visible="false" managed="false"/>
    
</StackPane>
