<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Tooltip?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.UserManagementScreenController"
      spacing="15.0" VBox.vgrow="ALWAYS"
      stylesheets="@../css/admin_dashboard_styles.css">
      
    <padding>
        <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
    </padding>
    
    <!-- Hero Header Banner -->
    <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label text="System Operator Management" styleClass="welcome-title"/>
        <Label text="Manage system operator accounts, configure authorization roles, and track active guard/admin registries." styleClass="welcome-subtitle"/>
    </VBox>
    
    <!-- Main Content Single Table Card -->
    <VBox spacing="15.0" VBox.vgrow="ALWAYS"
          style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 20px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
        
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <VBox spacing="2.0">
                <Label text="System Operators Directory" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
                <Label text="Super Admin Privileges Only" style="-fx-font-family: 'Inter', 'Segoe UI', sans-serif; -fx-font-size: 12px; -fx-text-fill: #E11D48; -fx-font-weight: bold;"/>
            </VBox>
        </HBox>
        
        <Separator/>
        
        <!-- Top Toolbar -->
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Search:" styleClass="form-label" style="-fx-padding: 0 5px 0 0;"/>
            <TextField fx:id="searchField" promptText="Search name, username, email..." styleClass="modern-textfield" prefHeight="38.0" prefWidth="250.0"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Add Operator" onAction="#handleAddOperator" styleClass="action-btn, action-btn-success" prefHeight="38.0" prefWidth="140.0"/>
            <Button fx:id="editBtn" text="Edit Operator" onAction="#handleEditOperator" styleClass="action-btn, action-btn-primary" prefHeight="38.0" prefWidth="140.0"/>
            <Button fx:id="deactivateBtn" text="Deactivate Operator" onAction="#handleDeactivate" styleClass="action-btn, action-btn-danger" prefHeight="38.0" prefWidth="160.0"/>
        </HBox>
        
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="400.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" text="User ID" prefWidth="70.0"/>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="120.0"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180.0"/>
                <TableColumn fx:id="colName" text="Full Name" prefWidth="150.0"/>
                <TableColumn fx:id="colRole" text="Role" prefWidth="100.0"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="80.0"/>
            </columns>
        </TableView>
    </VBox>
    
</VBox>
