<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.UserManagementScreenController"
      spacing="15.0" HBox.hgrow="ALWAYS">
    
    <!-- Left Side: System Operator List -->
    <VBox spacing="10.0" HBox.hgrow="ALWAYS" prefWidth="600.0">
        <Label text="System Operators directory" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Super Admin Privileges Only"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Deactivate Operator" onAction="#handleDeactivate" style="-fx-text-fill: red;"/>
        </HBox>
        
        <TableView fx:id="userTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colId" text="User ID" prefWidth="70.0"/>
                <TableColumn fx:id="colUsername" text="Username" prefWidth="120.0"/>
                <TableColumn fx:id="colEmail" text="Email" prefWidth="180.0"/>
                <TableColumn fx:id="colName" text="Full Name" prefWidth="150.0"/>
                <TableColumn fx:id="colRole" text="Role" prefWidth="100.0"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="80.0"/>
            </columns>
        </TableView>
    </VBox>
    
    <Separator orientation="VERTICAL"/>
    
    <!-- Right Side: Operator Details & Actions -->
    <VBox spacing="15.0" prefWidth="300.0">
        <Label text="Operator Details &amp; Actions" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
        
        <VBox spacing="5.0">
            <Label text="Full Name:"/>
            <TextField fx:id="fullNameField" promptText="e.g. John Doe"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Username:"/>
            <TextField fx:id="usernameField" promptText="(Read-only)" editable="false"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="Email:"/>
            <TextField fx:id="emailField" promptText="e.g. j.doe@example.com"/>
        </VBox>
        
        <VBox spacing="5.0">
            <Label text="System Role:"/>
            <ComboBox fx:id="roleBox" promptText="Select Role" prefWidth="200.0"/>
        </VBox>

        <VBox spacing="5.0">
            <Label text="Status:"/>
            <ComboBox fx:id="statusBox" promptText="Select Status" prefWidth="200.0"/>
        </VBox>
        
        <Separator/>
        
        <Button text="Onboard New Operator" onAction="#handleOnboard" prefWidth="200.0" style="-fx-font-weight: bold;"/>
        <Button text="Update Operator Details" onAction="#handleUpdate" prefWidth="200.0"/>
        <Button text="Change Role Only" onAction="#handleChangeRole" prefWidth="200.0"/>
    </VBox>
</HBox>
