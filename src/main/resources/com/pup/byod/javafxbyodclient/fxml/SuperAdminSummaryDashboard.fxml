<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" 
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-border-width: 0; -fx-padding: 0;" 
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pup.byod.javafxbyodclient.controller.SuperAdminSummaryDashboardController">
            
    <VBox spacing="24.0" styleClass="admin-dashboard-container" VBox.vgrow="ALWAYS">
        
        <!-- Hero Welcome Banner -->
        <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="15.0">
            <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                <Label fx:id="welcomeLabel" text="Welcome back, Super Admin!" styleClass="welcome-title"/>
                <Label text="System Configuration &amp; Operator Accounts Management Panel — Configure parameters and operators." styleClass="welcome-subtitle"/>
            </VBox>
            <Button text="Refresh Stats" onAction="#refreshStats" styleClass="refresh-btn"/>
        </HBox>
        
        <!-- Cards Row -->
        <HBox spacing="24.0" alignment="CENTER_LEFT" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <!-- Card 1: Total Operators -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Total Operators" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-blue">
                        <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5z" 
                                 styleClass="stat-icon-blue-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="totalOperatorsLabel" text="0" styleClass="stat-value, stat-value-blue"/>
            </VBox>
            
            <!-- Card 2: Active Operators -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Active Operators" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-purple">
                        <SVGPath content="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" 
                                 styleClass="stat-icon-purple-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="activeOperatorsLabel" text="0" styleClass="stat-value, stat-value-purple"/>
            </VBox>
            
            <!-- Card 3: Pending Accounts -->
            <VBox styleClass="stat-card" spacing="12.0" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Pending Accounts" styleClass="stat-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <StackPane styleClass="stat-icon-container, stat-icon-yellow">
                        <SVGPath content="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm0 18c-4.4 0-8-3.6-8-8s3.6-8 8-8 8 3.6 8 8-3.6 8-8 8zm.5-13H11v6l5.2 3.1.8-1.3-4.5-2.7V7z" 
                                 styleClass="stat-icon-yellow-svg"/>
                    </StackPane>
                </HBox>
                <Label fx:id="pendingOperatorsLabel" text="0" styleClass="stat-value, stat-value-orange"/>
            </VBox>
        </HBox>
        
        <Label text="Quick Access System Panels" styleClass="section-title"/>
        
        <!-- Quick Access Buttons (Horizontal Layout) -->
        <HBox spacing="20.0" alignment="CENTER_LEFT" fillHeight="false" maxWidth="Infinity" HBox.hgrow="ALWAYS">
            <!-- Operator Directory -->
            <Button onAction="#goToOperators" prefWidth="300.0" prefHeight="120.0" styleClass="shortcut-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Operator Directory" styleClass="shortcut-title" wrapText="true"/>
                            <Label text="Manage user accounts and roles" styleClass="shortcut-desc" wrapText="true"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- System Configuration -->
            <Button onAction="#goToConfiguration" prefWidth="300.0" prefHeight="120.0" styleClass="shortcut-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .43-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.49-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="System Configuration" styleClass="shortcut-title" wrapText="true"/>
                            <Label text="Configure core system parameters and settings" styleClass="shortcut-desc" wrapText="true"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
            
            <!-- Profile Management -->
            <Button onAction="#goToProfile" prefWidth="300.0" prefHeight="120.0" styleClass="shortcut-card" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                <graphic>
                    <HBox spacing="16.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <StackPane styleClass="shortcut-icon-container">
                            <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                                     styleClass="shortcut-icon"/>
                        </StackPane>
                        <VBox spacing="4.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <Label text="Profile Management" styleClass="shortcut-title" wrapText="true"/>
                            <Label text="Update personal credentials and settings" styleClass="shortcut-desc" wrapText="true"/>
                        </VBox>
                    </HBox>
                </graphic>
            </Button>
        </HBox>
        
    </VBox>
</ScrollPane>
