<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.SVGPath?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.SuperAdminSummaryDashboardController"
      spacing="20.0" styleClass="dashboard-container" VBox.vgrow="ALWAYS">
      
    <!-- Hero Welcome Banner -->
    <HBox styleClass="hero-banner" alignment="CENTER_LEFT" spacing="15.0">
        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
            <Label fx:id="welcomeLabel" text="Welcome back, Super Admin!" styleClass="hero-welcome"/>
            <Label text="System Configuration &amp; Operator Accounts Management Panel — Configure parameters and operators." styleClass="hero-subtitle"/>
        </VBox>
        <Button text="Refresh Stats" onAction="#refreshStats" styleClass="refresh-btn" style="-fx-background-color: white; -fx-text-fill: #1e3a8a; -fx-cursor: hand;"/>
    </HBox>
    
    <!-- Cards Row -->
    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <!-- Card 1: Total Operators -->
        <VBox styleClass="card">
            <Label text="Total Operators" styleClass="card-title"/>
            <Label fx:id="totalOperatorsLabel" text="0" styleClass="card-value"/>
        </VBox>
        
        <!-- Card 2: Active Operators -->
        <VBox styleClass="card">
            <Label text="Active Operators" styleClass="card-title"/>
            <Label fx:id="activeOperatorsLabel" text="0" styleClass="card-value"/>
        </VBox>
        
        <!-- Card 3: Pending Onboarding -->
        <VBox styleClass="card">
            <Label text="Pending Accounts" styleClass="card-title"/>
            <Label fx:id="pendingOperatorsLabel" text="0" styleClass="card-value"/>
        </VBox>
    </HBox>
    
    <Label text="Quick Access System Panels" styleClass="section-title"/>
    
    <!-- Quick Access Buttons -->
    <FlowPane hgap="15.0" vgap="15.0" prefWrapLength="800.0">
        <Button onAction="#goToOperators" prefWidth="380.0" styleClass="shortcut-card">
            <graphic>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <StackPane styleClass="shortcut-icon-container">
                        <!-- Group Icon -->
                        <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" styleClass="shortcut-icon"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="2.0">
                        <Label text="Operator Directory" styleClass="shortcut-title"/>
                        <Label text="Manage user accounts and roles" styleClass="shortcut-desc"/>
                    </VBox>
                </HBox>
            </graphic>
        </Button>
        <Button onAction="#goToConfiguration" prefWidth="380.0" styleClass="shortcut-card">
            <graphic>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <StackPane styleClass="shortcut-icon-container">
                        <!-- Settings Icon -->
                        <SVGPath content="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.06-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.06.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .43-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.49-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z" styleClass="shortcut-icon"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="2.0">
                        <Label text="System Configuration" styleClass="shortcut-title"/>
                        <Label text="Configure core system parameters and settings" styleClass="shortcut-desc"/>
                    </VBox>
                </HBox>
            </graphic>
        </Button>
        <Button onAction="#goToProfile" prefWidth="380.0" styleClass="shortcut-card">
            <graphic>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <StackPane styleClass="shortcut-icon-container">
                        <!-- Person Icon -->
                        <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" styleClass="shortcut-icon"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="2.0">
                        <Label text="Profile Management" styleClass="shortcut-title"/>
                        <Label text="Update personal credentials and settings" styleClass="shortcut-desc"/>
                    </VBox>
                </HBox>
            </graphic>
        </Button>
    </FlowPane>
    
</VBox>
