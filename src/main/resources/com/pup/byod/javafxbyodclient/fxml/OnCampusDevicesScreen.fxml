<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.pup.byod.javafxbyodclient.controller.OnCampusDevicesScreenController"
      spacing="15.0" VBox.vgrow="ALWAYS"
      stylesheets="@../css/admin_dashboard_styles.css">
      
    <padding>
        <Insets top="5.0" right="5.0" bottom="5.0" left="5.0"/>
    </padding>
    
    <!-- Hero Header Banner -->
    <VBox styleClass="welcome-banner" spacing="4.0" alignment="CENTER_LEFT" maxWidth="Infinity">
        <Label text="Devices Currently On-Campus" styleClass="welcome-title"/>
        <Label text="Real-time monitoring directory of all registered devices and their current campus checked-in status." styleClass="welcome-subtitle"/>
    </VBox>
    
    <!-- Registry Card Container -->
    <VBox spacing="12.0" VBox.vgrow="ALWAYS"
          style="-fx-background-color: #FFFFFF; -fx-border-color: #E2E8F0; -fx-border-width: 1px; -fx-border-radius: 12px; -fx-background-radius: 12px; -fx-padding: 16px; -fx-effect: dropshadow(three-pass-box, rgba(0, 0, 0, 0.04), 8, 0, 0, 2);">
        
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <VBox spacing="2.0" alignment="CENTER_LEFT">
                <Label text="Campus Presence Registry" style="-fx-font-family: 'Hanken Grotesk', 'Segoe UI Bold', 'Segoe UI', sans-serif; -fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #102A43;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <StackPane alignment="CENTER_LEFT" prefWidth="250.0">
                <TextField fx:id="searchField" promptText="Search by Student ID, Name, or Device SN" styleClass="modern-textfield, search-field-with-icon" prefHeight="35.0" maxWidth="Infinity"/>
                <Label text="🔍" mouseTransparent="true" style="-fx-padding: 0 0 0 10px; -fx-text-fill: #94A3B8; -fx-font-size: 13px;"/>
            </StackPane>
            <Button text="Refresh View" onAction="#loadStatus" styleClass="action-btn, action-btn-warning" prefHeight="35.0"/>
            <Button text="Export Presence" onAction="#handleExportPresence" styleClass="action-btn" prefHeight="35.0" style="-fx-background-color: #f1f5f9; -fx-border-color: #cbd5e1; -fx-border-radius: 8; -fx-text-fill: #475569;"/>
        </HBox>
        
        <TableView fx:id="statusTable" VBox.vgrow="ALWAYS" styleClass="modern-table" minHeight="300.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colStudentId" text="Student ID" prefWidth="120.0"/>
                <TableColumn fx:id="colStudentName" text="Student Name" prefWidth="180.0"/>
                <TableColumn fx:id="colCourseYearLevel" text="Course/Year" prefWidth="120.0"/>
                <TableColumn fx:id="colDeviceName" text="Device Name" prefWidth="170.0"/>
                <TableColumn fx:id="colSerialNumber" text="Serial Number" prefWidth="160.0"/>
                <TableColumn fx:id="colCheckedInTime" text="Checked-in Time" prefWidth="110.0"/>
                <TableColumn fx:id="colDetails" text="Details" prefWidth="100.0"/>
            </columns>
        </TableView>
        
    </VBox>
    
</VBox>
