sequenceDiagram
    actor Guard as Guard
    participant UI as JavaFX Gate Screen
    participant API as Spring Boot DeviceLogController
    participant Service as DeviceLogService
    participant DAO as DeviceLogDAO / DeviceDAO
    participant DB as PostgreSQL
    participant Audit as AuditLogDAO

    Guard->>UI: Search active device
    UI->>API: GET active device/latest state
    API->>Service: find latest device state
    Service->>DAO: query latest log/view
    DAO->>DB: SELECT latest device_logs
    DB-->>DAO: Latest event data
    DAO-->>Service: Result
    Service-->>API: Active device result
    API-->>UI: JSON result
    Guard->>UI: Confirm exit
    UI->>API: POST /device-logs event_type=exit logout_type=manual
    API->>Service: log manual exit
    Service->>DAO: insert device_logs row
    DAO->>DB: INSERT device_logs
    DB-->>DAO: Triggers validate approved active and alternation
    Service->>Audit: fn_write_audit_log DEVICE_EXIT
    Service-->>API: Success or rule error
    API-->>UI: HTTP response
