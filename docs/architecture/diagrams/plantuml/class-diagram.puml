@startuml
skinparam classAttributeIconSize 0

class User {
  userId
  username
  passwordHash
  fullName
  role
  status
}

class Student {
  studentId
  firstName
  lastName
  courseYearLevel
  status
}

class Device {
  deviceId
  studentId
  deviceName
  brand
  model
  serialNumber
  deviceType
  devicePurpose
  registrationStatus
  deviceStatus
  reviewedBy
  reviewedAt
}

class EventRequest {
  eventRequestId
  studentId
  responsiblePerson
  organization
  eventName
  approvalDocType
  approvalDocRef
  startDate
  endDate
  status
}

class EventRequestDevice {
  eventDeviceId
  eventRequestId
  deviceType
  serialNumber
  quantity
  verifiedBy
  verifiedAt
  deviceStatus
}

class DeviceLog {
  logId
  deviceId
  studentId
  eventType
  eventTime
  handledBy
  logoutType
  autoExit
}

class AuditLog {
  auditId
  userId
  actionType
  targetTable
  targetId
  oldValues
  newValues
}

class AuthController
class DeviceController
class EventRequestController
class DeviceLogController
class AuthService
class DeviceService
class EventRequestService
class DeviceLogService
class DeviceDAO
class EventRequestDAO
class DeviceLogDAO
class AuditLogDAO

Student "1" -- "0..*" Device
Student "1" -- "0..*" EventRequest
EventRequest "1" -- "0..*" EventRequestDevice
Device "1" -- "0..*" DeviceLog
User "1" -- "0..*" AuditLog
User "1" -- "0..*" DeviceLog

AuthController --> AuthService
DeviceController --> DeviceService
EventRequestController --> EventRequestService
DeviceLogController --> DeviceLogService
DeviceService --> DeviceDAO
EventRequestService --> EventRequestDAO
DeviceLogService --> DeviceLogDAO
DeviceLogService --> AuditLogDAO
@enduml
