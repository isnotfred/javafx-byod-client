@startuml
node "Authorized Campus Desktop" {
  artifact "JavaFX Desktop Client" as Frontend
  artifact "Backend URL Config" as Config
}

cloud "Railway" {
  node "Spring Boot Service" {
    artifact "REST API" as Backend
    artifact "Automatic Logout Scheduler" as Scheduler
  }
  database "PostgreSQL" as DB
}

Frontend --> Backend : HTTPS JSON
Backend --> DB : JDBC over TLS
Scheduler --> DB : JDBC over TLS
Config --> Frontend
@enduml
